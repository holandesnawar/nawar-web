---
import { sanityClient } from 'sanity:client'
import { PortableText } from 'astro-portabletext'
import Layout from '../layouts/Layout.astro'
import { WAITLIST_QUERY } from '../sanity/queries'

export const prerender = true

const page = await sanityClient.fetch(WAITLIST_QUERY)
---

<Layout
  title={page?.seo?.title || 'Lista de espera — Nawar Academia'}
  description={page?.seo?.description || 'Apúntate a la lista de espera'}
>
  <div class="max-w-2xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold mb-4">
      {page?.headline || page?.title || 'Lista de espera'}
    </h1>

    {page?.body && (
      <div class="prose mb-10">
        <PortableText value={page.body} />
      </div>
    )}

    <div class="bg-gray-50 rounded-2xl p-8">
      <h2 class="font-semibold text-xl mb-6">
        {page?.formTitle || 'Apúntate a la lista de espera'}
      </h2>
      <form
        name="lista-espera"
        method="POST"
        data-netlify="true"
        class="flex flex-col gap-4"
        action="/gracias"
      >
        <input type="hidden" name="form-name" value="lista-espera" />
        <div>
          <label class="block text-sm font-medium mb-1" for="nombre">Nombre</label>
          <input
            id="nombre"
            name="nombre"
            type="text"
            required
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-300"
          />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1" for="email">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-300"
          />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1" for="nivel">Nivel actual de neerlandés</label>
          <select
            id="nivel"
            name="nivel"
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gray-300 bg-white"
          >
            <option value="">Selecciona...</option>
            <option value="cero">Cero — nunca he estudiado</option>
            <option value="basico">Básico — conozco algunas palabras</option>
            <option value="intermedio">Intermedio — puedo mantener conversaciones sencillas</option>
            <option value="avanzado">Avanzado — quiero perfeccionar</option>
          </select>
        </div>
        <button
          type="submit"
          class="bg-gray-900 text-white px-6 py-3 rounded-full text-sm font-medium hover:bg-gray-700 transition-colors self-start"
        >
          {page?.formButtonText || 'Quiero apuntarme'}
        </button>
      </form>
    </div>
  </div>
</Layout>
