---
// Página de preview de la imagen Open Graph (1200×630).
// Abre /og-preview en Chrome → DevTools → modo dispositivo 1200x630 →
// capture full-size screenshot → guardar como public/og-image.png
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>OG Image Preview</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&display=swap"
    rel="stylesheet"
  />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #0a0043; }
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }

    /* OG canvas exacto: 1200×630 */
    .og {
      position: relative;
      width: 1200px;
      height: 630px;
      background: #1D0084;
      overflow: hidden;
      font-family: 'Poppins', system-ui, sans-serif;
    }

    /* Halo radial suave desde el centro */
    .og-glow {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, rgba(77,163,255,0.18) 0%, transparent 60%);
      pointer-events: none;
    }

    /* Semicirculos casi fuera del canvas: solo un 10% asoma por los lados */
    .og-orb {
      position: absolute;
      top: 50%;
      width: 900px;
      height: 900px;
      transform: translateY(-50%);
      border-radius: 50%;
      pointer-events: none;
      border: 1.5px solid rgba(77,163,255,0.5);
      background: radial-gradient(
        circle,
        rgba(77,163,255,0.28) 60%,
        rgba(77,163,255,0.15) 85%,
        rgba(77,163,255,0.05) 97%,
        transparent 100%
      );
    }
    /* 900 width, 810 off-screen → 90px visible (10% del diametro) */
    .og-orb-left  { left: -810px; }
    .og-orb-right { right: -810px; }

    /* Contenido centrado */
    .og-text-wrap {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 60px 140px;
      text-align: center;
      z-index: 2;
    }
    .og-title {
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.02em;
      white-space: nowrap; /* fuerza 1 visual line por span */
    }
    .og-title-white {
      font-size: 46px;
      background: linear-gradient(180deg, #ffffff 0%, rgba(255,255,255,0.62) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      display: block;
    }
    .og-title-blue {
      font-size: 46px;
      color: #4da3ff;
      display: block;
      margin-top: 8px;
    }

    /* Logo centrado abajo */
    .og-logo {
      position: absolute;
      left: 50%;
      bottom: 60px;
      transform: translateX(-50%);
      height: 56px;
      width: auto;
      filter: drop-shadow(0 4px 18px rgba(77,163,255,0.4));
      z-index: 2;
    }
  </style>
</head>
<body>
  <div class="og">
    <div class="og-glow"></div>

    <!-- Semicirculos asomando 10% desde los bordes -->
    <div class="og-orb og-orb-left"></div>
    <div class="og-orb og-orb-right"></div>

    <!-- Texto en EXACTAMENTE 2 lineas -->
    <div class="og-text-wrap">
      <div class="og-title">
        <span class="og-title-white">Descubre el método de aprender neerlandés</span>
        <span class="og-title-blue">que el mundo hispano necesita.</span>
      </div>
    </div>

    <!-- Logo Nawar -->
    <img
      src="https://d1yei2z3i6k35z.cloudfront.net/9533860/671a9c9265e23_Logo_Nawar_2.png"
      alt="Holandés Nawar"
      class="og-logo"
    />
  </div>
</body>
</html>
