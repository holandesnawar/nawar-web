---
import Layout from '../layouts/Layout.astro'
import NavbarLanding from '../components/NavbarLanding'
import FooterLanding from '../components/FooterLanding'

export const prerender = false
---

<Layout
  title="Contacto — Nawar Academia"
  description="Contacta con Nawar Academia. Estamos para ayudarte con cualquier duda sobre nuestros cursos de neerlandés."
>
  <NavbarLanding client:load />

  <!-- Hero -->
  <section data-navbar="dark" class="relative bg-[#1D0084] overflow-hidden pt-36 pb-24">
    <div aria-hidden class="absolute inset-0 pointer-events-none">
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px]"
        style="background: radial-gradient(ellipse at center top, rgba(11,109,240,0.38) 0%, transparent 65%)"
      />
    </div>
    <div aria-hidden class="absolute inset-0 dots-dark pointer-events-none" />

    <div class="relative max-w-2xl mx-auto px-6 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#025dc7] text-[#e0f2ff] eyebrow mb-6">
        <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Estamos aquí
      </span>
      <h1 class="title text-white mb-4">
        Hablemos de tu<br/>
        <span class="text-[#4da3ff]">aprendizaje</span>
      </h1>
      <p class="text-[18px] text-white/55 leading-relaxed max-w-md mx-auto">
        ¿Tienes dudas sobre los cursos o el método? Escríbenos y te respondemos en menos de 24 horas.
      </p>
    </div>
  </section>

  <!-- Form card -->
  <section data-navbar="light" class="relative bg-white overflow-hidden py-24">
    <div aria-hidden class="absolute inset-0 dots-light pointer-events-none opacity-60" />

    <div class="relative max-w-xl mx-auto px-6">

      <!-- Contact options row -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
        <a
          href="mailto:hola@holandesnawar.com"
          class="group card-soft rounded-2xl p-5 flex items-center gap-4 hover:no-underline"
        >
          <div class="w-10 h-10 rounded-2xl bg-[#1D0084]/8 border border-[#1D0084]/12 flex items-center justify-center shrink-0 group-hover:bg-[#1D0084]/14 transition-colors">
            <svg class="w-5 h-5 text-[#1D0084]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-[12px] text-[#9CA3AF] font-medium">Email directo</p>
            <p class="text-[14px] text-[#1D0084] font-semibold">hola@holandesnawar.com</p>
          </div>
        </a>

        <div class="card-soft rounded-2xl p-5 flex items-center gap-4">
          <div class="w-10 h-10 rounded-2xl bg-[#1D0084]/8 border border-[#1D0084]/12 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-[#1D0084]" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-[12px] text-[#9CA3AF] font-medium">Tiempo de respuesta</p>
            <p class="text-[14px] text-[#1D0084] font-semibold">Menos de 24 horas</p>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="bg-white border border-[#DDE6F5] rounded-3xl p-8 md:p-10 shadow-[0_4px_40px_rgba(29,0,132,0.08)]">
        <h2 class="text-[20px] font-semibold text-[#1D0084] mb-6" style="font-family: var(--font-poppins), system-ui, sans-serif">
          Envíanos un mensaje
        </h2>

        <form
          id="contact-form"
          class="space-y-5"
          novalidate
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-[13px] font-medium text-[#374151] mb-1.5" for="nombre">Nombre</label>
              <input
                id="nombre"
                name="nombre"
                type="text"
                required
                placeholder="Tu nombre"
                class="w-full border border-[#DDE6F5] rounded-xl px-4 py-3 text-[14px] text-[#1D0084] placeholder:text-[#9CA3AF] bg-[#F8FAFF] focus:outline-none focus:border-[#025dc7]/50 focus:ring-2 focus:ring-[#025dc7]/10 transition-all"
              />
            </div>
            <div>
              <label class="block text-[13px] font-medium text-[#374151] mb-1.5" for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="tu@email.com"
                class="w-full border border-[#DDE6F5] rounded-xl px-4 py-3 text-[14px] text-[#1D0084] placeholder:text-[#9CA3AF] bg-[#F8FAFF] focus:outline-none focus:border-[#025dc7]/50 focus:ring-2 focus:ring-[#025dc7]/10 transition-all"
              />
            </div>
          </div>

          <div>
            <label class="block text-[13px] font-medium text-[#374151] mb-1.5" for="asunto">Asunto</label>
            <select
              id="asunto"
              name="asunto"
              class="w-full border border-[#DDE6F5] rounded-xl px-4 py-3 text-[14px] text-[#1D0084] bg-[#F8FAFF] focus:outline-none focus:border-[#025dc7]/50 focus:ring-2 focus:ring-[#025dc7]/10 transition-all appearance-none"
            >
              <option value="">Selecciona un asunto</option>
              <option value="cursos">Información sobre cursos</option>
              <option value="metodo">El método Nawar</option>
              <option value="precio">Precio y formas de pago</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div>
            <label class="block text-[13px] font-medium text-[#374151] mb-1.5" for="mensaje">Mensaje</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows={5}
              required
              placeholder="Cuéntanos en qué podemos ayudarte..."
              class="w-full border border-[#DDE6F5] rounded-xl px-4 py-3 text-[14px] text-[#1D0084] placeholder:text-[#9CA3AF] bg-[#F8FAFF] focus:outline-none focus:border-[#025dc7]/50 focus:ring-2 focus:ring-[#025dc7]/10 transition-all resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full flex items-center justify-center gap-2.5 px-7 py-3.5 rounded-xl bg-[#1D0084] text-white text-[15px] font-semibold hover:bg-[#025dc7] transition-all duration-200 shadow-[0_4px_20px_rgba(29,0,132,0.20)] hover:scale-[1.01]"
          >
            Enviar mensaje
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </button>
        </form>

        <!-- Success state (hidden by default) -->
        <div id="success-msg" class="hidden text-center py-8">
          <div class="w-14 h-14 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="text-[18px] font-semibold text-[#1D0084] mb-2">¡Mensaje enviado!</h3>
          <p class="text-[14px] text-[#5A6480]">Te respondemos en menos de 24 horas. Revisa tu bandeja de entrada.</p>
        </div>
      </div>
    </div>
  </section>

  <FooterLanding client:load />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null
  const successMsg = document.getElementById('success-msg')
  const submitBtn = document.getElementById('submit-btn')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form.checkValidity()) { form.reportValidity(); return }

    if (submitBtn) {
      submitBtn.textContent = 'Enviando…'
      submitBtn.setAttribute('disabled', 'true')
    }

    // Simulated send — replace with your email service (Resend, Formspree, etc.)
    await new Promise(r => setTimeout(r, 1000))

    form.classList.add('hidden')
    successMsg?.classList.remove('hidden')
  })
</script>
