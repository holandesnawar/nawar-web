---
import Layout from '../layouts/Layout.astro'
import NavbarLanding from '../components/NavbarLanding'
import FooterNuevo from '../components/FooterNuevo.astro'
import '../styles/nawar-sections.css'

export const prerender = false
---

<Layout
  title="Nawar | Contacto"
  description="¿Tienes dudas sobre nuestros cursos de neerlandés? Contacta con Nawar Academia y te responderemos en menos de 24 horas para ayudarte a dar el siguiente paso."
>
  <NavbarLanding client:load />

  <section data-navbar="dark" class="ct-section">
    <!-- Background -->
    <div class="ct-bg" aria-hidden="true"></div>
    <div class="ct-glow" aria-hidden="true"></div>
    <div class="dots-dark ct-dots" aria-hidden="true"></div>

    <div class="ct-container">

      <!-- Top: Title + subtitle -->
      <div class="ct-top">
        <span class="badge-dark" style="margin-bottom: 24px;">CONTACTO</span>
        <h1 class="ct-title">Escríbenos y cuéntanos<br><span style="color: #4da3ff; -webkit-text-fill-color: #4da3ff;">cómo podemos ayudarte.</span></h1>
        <p class="ct-sub">¿Tienes dudas sobre los cursos o el método? Escríbenos y te respondemos en menos de 24 horas.</p>
      </div>

      <div class="ct-columns">
        <!-- Left: Image -->
        <div class="ct-image-side">
          <div class="ct-image-wrap">
            <img
              src="https://d1yei2z3i6k35z.cloudfront.net/9533860/676188e625099_Tulipfield_NL.jpg"
              alt="Campo de tulipanes"
              class="ct-image"
            />
          </div>
        </div>

        <!-- Right: Form — sin panel wrapper -->
        <div class="ct-form-side">
          <form id="contact-form" class="ct-form" novalidate>
            <div class="ct-row">
              <div class="ct-field">
                <label class="ct-label" for="nombre">Nombre</label>
                <input id="nombre" name="nombre" type="text" required placeholder="Tu nombre" class="ct-input" />
              </div>
              <div class="ct-field">
                <label class="ct-label" for="email">Correo</label>
                <input id="email" name="email" type="email" required placeholder="tu@email.com" class="ct-input" />
              </div>
            </div>

            <div class="ct-field">
              <label class="ct-label" for="asunto">Asunto</label>
              <input id="asunto" name="asunto" type="text" required placeholder="¿Sobre qué quieres hablar?" class="ct-input" />
            </div>

            <div class="ct-field">
              <label class="ct-label" for="mensaje">Mensaje</label>
              <textarea id="mensaje" name="mensaje" rows="5" required placeholder="¿En qué podemos ayudarte?" class="ct-input" style="resize:none;"></textarea>
            </div>

            <button type="submit" id="submit-btn" class="ct-submit">
              Enviar mensaje
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </button>

            <p class="ct-privacy">Al enviar aceptas nuestra <a href="#">política de privacidad</a>.</p>
          </form>

          <div id="success-msg" style="display:none;" class="ct-success">
            <div class="ct-success-icon">
              <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="ct-success-title">¡Mensaje enviado!</h3>
            <p class="ct-success-sub">Te respondemos en menos de 24 horas.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <FooterNuevo />
</Layout>

<style>
/* ── Section ── */
.ct-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  background: #1D0084;
  padding: 140px 0 80px;
}
.ct-bg {
  position: absolute; inset: 0;
  background: #1D0084;
}
.ct-glow {
  position: absolute;
  top: -10%; left: 50%; transform: translateX(-50%);
  width: 900px; height: 600px;
  background: radial-gradient(ellipse at center top, rgba(11,109,240,0.35) 0%, transparent 65%);
  pointer-events: none;
}
.ct-dots {
  position: absolute; inset: 0; pointer-events: none; opacity: 0.4;
}
.ct-container {
  position: relative; z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 32px;
  width: 100%;
}

/* Top */
.ct-top {
  text-align: center;
  margin-bottom: 48px;
}
.ct-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 500;
  letter-spacing: -0.025em;
  line-height: 1.12;
  margin-bottom: 14px;
  background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.45) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.ct-sub {
  font-size: 16px;
  color: rgba(255,255,255,0.88);
  line-height: 1.65;
  max-width: 520px;
  margin: 0 auto;
}

/* Columns */
.ct-columns {
  display: grid;
  grid-template-columns: 0.4fr 0.6fr;
  gap: 48px;
  align-items: start;
}

/* ── Form — sin panel wrapper, abierto ── */
.ct-form-side { padding-top: 8px; }
.ct-form { display: flex; flex-direction: column; gap: 20px; }
.ct-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.ct-field { display: flex; flex-direction: column; gap: 8px; }
.ct-label {
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,0.95);
  letter-spacing: 0.01em;
}
.ct-input {
  padding: 15px 18px; border-radius: 12px;
  border: 1px solid rgba(255,255,255,1);
  background: rgba(255,255,255,0.95);
  font-size: 15px; color: #1D0084;
  font-family: inherit; outline: none; width: 100%;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}
.ct-input::placeholder { color: rgba(29,0,132,0.55); }
.ct-input:focus {
  border-color: #4da3ff;
  background: #fff;
  outline: none;
}
.ct-submit {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  padding: 16px; border-radius: 12px; border: none; cursor: pointer;
  background: #4da3ff; color: #1D0084;
  font-size: 15px; font-weight: 700; font-family: inherit;
  margin-top: 4px;
  transition: background 0.2s;
}
.ct-submit:hover { background: #3391f0; }
.ct-privacy { font-size: 12px; color: rgba(255,255,255,0.40); text-align: center; }
.ct-privacy a { color: rgba(255,255,255,0.60); text-decoration: underline; }

/* ── Success ── */
.ct-success { text-align: center; padding: 32px 0; }
.ct-success-icon {
  width: 52px; height: 52px; border-radius: 50%;
  background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.30);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 14px; color: #10b981;
}
.ct-success-title { font-family: 'Poppins', system-ui, sans-serif; font-size: 20px; font-weight: 600; color: #fff; margin-bottom: 6px; }
.ct-success-sub { font-size: 14px; color: rgba(255,255,255,0.50); }

/* ── Image ── */
.ct-image-side { display: flex; align-items: flex-start; }
.ct-image-wrap {
  position: relative;
  width: 100%;
  border-radius: 20px;
  overflow: hidden;
  aspect-ratio: 3/4;
}
.ct-image {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .ct-columns { grid-template-columns: 1fr; gap: 32px; }
  .ct-image-side { display: none; }
  .ct-section { padding: 120px 0 60px; }
  .ct-container { padding: 0 20px; }
  .ct-top { text-align: left; display: flex; flex-direction: column; align-items: flex-start; }
  .ct-sub { margin-left: 0; text-align: left; }
}
@media (max-width: 540px) {
  .ct-row { grid-template-columns: 1fr; }
}
</style>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement | null
  const successMsg = document.getElementById('success-msg') as HTMLElement | null
  const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement | null

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!form.checkValidity()) { form.reportValidity(); return }

    const nombre  = (form.querySelector('#nombre')  as HTMLInputElement)?.value?.trim()
    const email   = (form.querySelector('#email')   as HTMLInputElement)?.value?.trim()
    const asunto  = (form.querySelector('#asunto')  as HTMLInputElement)?.value?.trim()
    const mensaje = (form.querySelector('#mensaje') as HTMLTextAreaElement)?.value?.trim()

    if (submitBtn) { submitBtn.textContent = 'Enviando…'; submitBtn.disabled = true }

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, email, asunto, mensaje }),
      })
      const data = await res.json()

      if (data.success) {
        form.style.display = 'none'
        if (successMsg) successMsg.style.display = 'block'
      } else {
        if (submitBtn) { submitBtn.textContent = 'Error — inténtalo de nuevo'; submitBtn.disabled = false }
        console.error('Error contacto:', data.error)
      }
    } catch {
      if (submitBtn) { submitBtn.textContent = 'Error — inténtalo de nuevo'; submitBtn.disabled = false }
    }
  })
</script>
