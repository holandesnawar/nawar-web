---
import { sanityClient } from 'sanity:client'
import Layout from '../layouts/Layout.astro'
import NavbarLanding from '../components/NavbarLanding'
import FeaturesSection from '../components/FeaturesSection.astro'
import FooterNuevo from '../components/FooterNuevo.astro'
import '../styles/nawar-sections.css'
import { LANDING_QUERY } from '../sanity/queries'

export const prerender = false

const page = await sanityClient.fetch(LANDING_QUERY)
const features = page?.features ?? []
---

<Layout
  title="Nuestra Visión — Nawar Academia"
  description="Conoce la visión detrás de Nawar Academia y por qué existimos para los hispanohablantes que quieren aprender neerlandés."
>
  <NavbarLanding client:load />

  <!-- Video Hero — title at bottom, center free -->
  <section class="vision-hero" data-navbar="dark">
    <video
      class="vision-video"
      src="https://docs.holandesnawar.com/audio/Sobrenosotros1-ezgif.com-webp-to-mp4-converter%20(1).mp4"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <div class="vision-overlay" aria-hidden="true"></div>

    <div class="vision-content">
      <h1 class="vision-title">
        Ayudarte a aprender <span class="vision-accent">neerlandés</span>
      </h1>
      <p class="vision-sub">
        Nawar nació para que ningún hispanohablante tenga que enfrentarse al neerlandés sin el método que realmente funciona.
      </p>
      <a href="#vision" class="vision-cta">
        Empieza a aprender hoy mismo
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Vision statement — white, left-aligned, large per-phrase animation -->
  <section id="vision" class="section-light" data-navbar="light" style="padding: 120px 0 100px;">
    <div class="inner" style="max-width: 860px;">

      <div class="vision-phrases">
        <p class="vision-phrase sr-bi">Creemos que aprender neerlandés no debería ser una barrera. Para vivir, trabajar e integrarte en Países Bajos, el idioma es la clave. Pero nadie lo enseñaba desde el español. Con el método correcto, con quien lo entiende, todo cambia. Por eso creamos Nawar: un método diseñado desde el español, por quienes entienden tus retos, tus dudas y tu punto de partida. Más de 600 estudiantes hispanohablantes de 15 países lo han comprobado. El neerlandés no es imposible — solo necesitabas el método adecuado.</p>
      </div>

      <div class="sr-bi" style="margin-top:56px;">
        <a href="#" class="vision-community-btn">
          Unirse a la comunidad
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- El método Nawar -->
  <FeaturesSection features={features} />

  <!-- Values -->
  <section class="section-dark py-section" data-navbar="dark">
    <div class="hero-glow1" aria-hidden="true"></div>
    <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></div>
    <div class="inner" style="position:relative;z-index:1;">
      <div style="text-align:center;max-width:520px;margin:0 auto 56px;" class="sr">
        <span class="badge-dark">Nuestros valores</span>
        <h2 class="title" style="color:#fff;">Lo que nos guía cada día</h2>
      </div>
      <div class="vision-values-grid">
        <div class="vision-value-card">
          <div class="vision-value-icon">🎯</div>
          <h3 class="vision-value-title">Método desde el español</h3>
          <p class="vision-value-text">Explicamos el neerlandés partiendo de lo que ya conoces, sin pasar por el inglés ni los métodos genéricos.</p>
        </div>
        <div class="vision-value-card">
          <div class="vision-value-icon">🤝</div>
          <h3 class="vision-value-title">Comunidad real</h3>
          <p class="vision-value-text">Aprendes rodeado de personas que viven exactamente la misma experiencia que tú, con los mismos retos.</p>
        </div>
        <div class="vision-value-card">
          <div class="vision-value-icon">🔴</div>
          <h3 class="vision-value-title">En directo, siempre</h3>
          <p class="vision-value-text">Las clases son en vivo porque la interacción real es insustituible para aprender un idioma de verdad.</p>
        </div>
      </div>
    </div>
  </section>

  <FooterNuevo />
</Layout>

<style>
/* ── Video Hero ── */
.vision-hero {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: #0a0030;
}
.vision-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.vision-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(10, 0, 48, 0.10) 0%,
    rgba(10, 0, 48, 0.05) 30%,
    rgba(10, 0, 48, 0.70) 65%,
    rgba(10, 0, 48, 0.94) 100%
  );
  z-index: 1;
}
.vision-content {
  position: relative;
  z-index: 3;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px 72px;
  text-align: left;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.vision-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(30px, 4.2vw, 58px);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.08;
  color: #fff;
  margin-bottom: 18px;
  max-width: 640px;
  text-align: left;
}
.vision-accent { color: #4da3ff; }
.vision-sub {
  font-size: clamp(14px, 1.4vw, 17px);
  color: rgba(255,255,255,0.70);
  line-height: 1.65;
  max-width: 440px;
  margin-bottom: 32px;
  text-align: left;
}
.vision-cta {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 15px 28px; border-radius: 12px;
  background: #4da3ff; color: #1D0084;
  font-size: 15px; font-weight: 700;
  text-decoration: none;
}
@media (max-width: 640px) {
  .vision-content { padding: 0 20px 52px; }
  .vision-title { font-size: clamp(26px, 7vw, 36px); }
}

/* ── Vision text phrases ── */
.vision-phrases {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.vision-phrase {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(22px, 2.6vw, 34px);
  font-weight: 400;
  letter-spacing: -0.015em;
  line-height: 1.55;
  color: #1D0084;
  margin: 0;
  padding: 10px 0;
}
.vision-community-btn {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 32px; border-radius: 14px;
  background: #4da3ff; color: #1D0084;
  font-size: 15px; font-weight: 700;
  text-decoration: none;
}


/* ── Values ── */
.vision-values-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}
@media (min-width: 768px) {
  .vision-values-grid { grid-template-columns: 1fr 1fr 1fr; }
}
.vision-value-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 20px;
  padding: 32px 28px;
}
.vision-value-icon { font-size: 32px; margin-bottom: 16px; }
.vision-value-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10px;
}
.vision-value-text { font-size: 14px; color: rgba(255,255,255,0.60); line-height: 1.65; }
</style>
