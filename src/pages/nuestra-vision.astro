---
import Layout from '../layouts/Layout.astro'
import NavbarLanding from '../components/NavbarLanding'
import FooterNuevo from '../components/FooterNuevo.astro'
import '../styles/nawar-sections.css'

export const prerender = false
---

<Layout
  title="Nuestra Visión — Nawar Academia"
  description="Conoce la visión detrás de Nawar Academia y por qué existimos para los hispanohablantes que quieren aprender neerlandés."
>
  <NavbarLanding client:load />

  <!-- Video Hero — title at bottom, center free -->
  <section class="vision-hero" data-navbar="dark">
    <video
      class="vision-video"
      src="https://docs.holandesnawar.com/audio/Sobrenosotros1-ezgif.com-webp-to-mp4-converter%20(1).mp4"
      autoplay
      muted
      loop
      playsinline
    ></video>
    <div class="vision-overlay" aria-hidden="true"></div>

    <div class="vision-content">
      <h1 class="vision-title">
        Ayudarte a aprender <span class="vision-accent">neerlandés</span>
      </h1>
      <p class="vision-sub">
        Nawar nació para que ningún hispanohablante tenga que enfrentarse al neerlandés sin el método que realmente funciona.
      </p>
      <a href="#vision" class="vision-cta">
        Empieza a aprender hoy mismo
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Vision statement — white, left-aligned, large -->
  <section id="vision" class="section-light" data-navbar="light" style="padding: 120px 0 100px;">
    <div class="inner" style="max-width: 900px;">

      <div class="vision-phrase-block sr-bi">
        <p class="vision-phrase">Creemos que aprender neerlandés no debería ser una barrera.</p>
      </div>
      <div class="vision-phrase-block sr-bi">
        <p class="vision-phrase">Para vivir, trabajar e integrarte en Países Bajos, el idioma es la clave.</p>
      </div>
      <div class="vision-phrase-block sr-bi">
        <p class="vision-phrase">Pero nadie lo enseñaba desde el español.</p>
      </div>
      <div class="vision-phrase-block sr-bi">
        <p class="vision-phrase">Con el método correcto, con quien lo entiende, todo cambia.</p>
      </div>
      <div class="vision-phrase-block sr-bi" style="margin-top:16px;">
        <p class="vision-phrase">Por eso creamos Nawar: un método diseñado desde el español, por quienes entienden tus retos, tus dudas y tu punto de partida.</p>
      </div>
      <div class="vision-phrase-block sr-bi">
        <p class="vision-phrase">+600 estudiantes hispanohablantes de 15 países lo han comprobado. El neerlandés no es imposible — solo necesitabas el método adecuado.</p>
      </div>

      <div class="sr-bi" style="margin-top:48px;">
        <a href="#" class="vision-community-btn">
          Unirse a la comunidad
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section-dark py-section" data-navbar="dark">
    <div class="hero-glow1" aria-hidden="true"></div>
    <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></div>
    <div class="inner" style="position:relative;z-index:1;">
      <div class="pq-header sr" style="margin-bottom:56px;">
        <span class="badge-dark">Nuestros valores</span>
        <h2 class="title" style="color:#fff;max-width:520px;">Lo que nos guía cada día</h2>
      </div>
      <div class="vision-values-grid">
        <div class="vision-value-card">
          <div class="vision-value-icon">🎯</div>
          <h3 class="vision-value-title">Método desde el español</h3>
          <p class="vision-value-text">Explicamos el neerlandés partiendo de lo que ya conoces, sin pasar por el inglés ni los métodos genéricos.</p>
        </div>
        <div class="vision-value-card">
          <div class="vision-value-icon">🤝</div>
          <h3 class="vision-value-title">Comunidad real</h3>
          <p class="vision-value-text">Aprendes rodeado de personas que viven exactamente la misma experiencia que tú, con los mismos retos.</p>
        </div>
        <div class="vision-value-card">
          <div class="vision-value-icon">🔴</div>
          <h3 class="vision-value-title">En directo, siempre</h3>
          <p class="vision-value-text">Las clases son en vivo porque la interacción real es insustituible para aprender un idioma de verdad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-light py-section" data-navbar="light" style="text-align:center;">
    <div class="dots-light" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;opacity:0.5;"></div>
    <div class="inner" style="position:relative;z-index:1;max-width:560px;">
      <span class="badge-light">Únete ahora</span>
      <h2 class="title" style="color:#1D0084;margin-bottom:20px;">Empieza tu camino con el neerlandés</h2>
      <p style="font-size:17px;color:#5A6480;line-height:1.7;margin-bottom:36px;">
        Apúntate a la lista de espera y sé el primero en saber cuándo abrimos nuevas plazas.
      </p>
      <a href="/" class="btn-primary" style="font-size:16px;padding:18px 36px;">
        Ver el método completo
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>

  <FooterNuevo />
</Layout>

<style>
/* ── Video Hero ── */
.vision-hero {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  background: #0a0030;
}
.vision-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.vision-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(10, 0, 48, 0.20) 0%,
    rgba(10, 0, 48, 0.10) 40%,
    rgba(10, 0, 48, 0.75) 75%,
    rgba(10, 0, 48, 0.95) 100%
  );
  z-index: 1;
}
.vision-content {
  position: relative;
  z-index: 3;
  width: 100%;
  max-width: 1152px;
  margin: 0 auto;
  padding: 0 24px 80px;
}
.vision-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(32px, 4.5vw, 62px);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.08;
  color: #fff;
  margin-bottom: 20px;
  max-width: 700px;
}
.vision-accent { color: #4da3ff; }
.vision-sub {
  font-size: clamp(15px, 1.5vw, 18px);
  color: rgba(255,255,255,0.72);
  line-height: 1.65;
  max-width: 480px;
  margin-bottom: 36px;
}
.vision-cta {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 32px; border-radius: 14px;
  background: #4da3ff; color: #1D0084;
  font-size: 15px; font-weight: 700;
  text-decoration: none;
}

/* ── Vision phrases ── */
.vision-phrase-block { margin-bottom: 8px; }
.vision-phrase {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(28px, 3.8vw, 52px);
  font-weight: 600;
  letter-spacing: -0.022em;
  line-height: 1.15;
  color: #1D0084;
}
.vision-phrase-small {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(22px, 2.8vw, 38px);
  font-weight: 600;
  letter-spacing: -0.018em;
  line-height: 1.2;
  color: #1D0084;
  opacity: 0.65;
}
.vision-community-btn {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 32px; border-radius: 14px;
  background: #4da3ff; color: #1D0084;
  font-size: 15px; font-weight: 700;
  text-decoration: none;
}


/* ── Values ── */
.vision-values-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}
@media (min-width: 768px) {
  .vision-values-grid { grid-template-columns: 1fr 1fr 1fr; }
}
.vision-value-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.10);
  border-radius: 20px;
  padding: 32px 28px;
}
.vision-value-icon { font-size: 32px; margin-bottom: 16px; }
.vision-value-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10px;
}
.vision-value-text { font-size: 14px; color: rgba(255,255,255,0.60); line-height: 1.65; }
</style>
