---
import { sanityClient } from 'sanity:client'
import { PortableText } from 'astro-portabletext'
import Layout from '../../layouts/Layout.astro'
import NavbarLanding from '../../components/NavbarLanding'
import FooterNuevo from '../../components/FooterNuevo.astro'
import '../../styles/nawar-sections.css'
import BlogTOC from '../../components/BlogTOC'
import BlogShare from '../../components/BlogShare'
import { POST_QUERY, POST_SLUGS_QUERY, RELATED_POSTS_QUERY } from '../../sanity/queries'
import imageUrlBuilder from '@sanity/image-url'

export const prerender = true

export async function getStaticPaths() {
  const slugs = await sanityClient.fetch(POST_SLUGS_QUERY)
  return slugs.map((item: { slug: string }) => ({ params: { slug: item.slug } }))
}

const { slug } = Astro.params
const post = await sanityClient.fetch(POST_QUERY, { slug })

if (!post) return Astro.redirect('/blog')

const relatedPosts = await sanityClient.fetch(RELATED_POSTS_QUERY, { slug })

const CATEGORY_META: Record<string, { label: string; className: string }> = {
  inburgering:   { label: 'Inburgering',   className: 'bp-chip--inbu' },
  cultura:       { label: 'Cultura',       className: 'bp-chip--cult' },
  vocabulario:   { label: 'Vocabulario',   className: 'bp-chip--voca' },
  pronunciacion: { label: 'Pronunciación', className: 'bp-chip--pron' },
}

const builder = imageUrlBuilder(sanityClient)
const urlFor  = (source: any) => builder.image(source)

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })

const postOgImage = post.coverImage
  ? urlFor(post.coverImage).width(1200).height(630).fit('crop').url()
  : 'https://docs.holandesnawar.com/iconos/og-image.png'

const canonicalURL = `https://www.holandesnawar.com/blog/${slug}`
---

<Layout
  title={post.seo?.title || post.title}
  description={post.seo?.description || post.excerpt}
  ogImage={postOgImage}
  canonicalURL={canonicalURL}
>
  <NavbarLanding client:load />

  <!-- Hero -->
  <section data-navbar="dark" class="relative bg-[#1D0084] overflow-hidden pt-36 pb-16">
    <div aria-hidden class="absolute inset-0 pointer-events-none">
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[700px]"
        style="background: radial-gradient(ellipse at center top, rgba(11,109,240,0.38) 0%, transparent 65%)"
      />
    </div>
    <div aria-hidden class="absolute inset-0 dots-dark pointer-events-none" />

    <div class="relative max-w-4xl mx-auto px-6">
      {post.category && CATEGORY_META[post.category] && (
        <div class="mb-5">
          <span class={`bp-chip ${CATEGORY_META[post.category].className}`}>
            {CATEGORY_META[post.category].label}
          </span>
        </div>
      )}
      <div class="flex items-center gap-3 mb-6">
        <a href="/blog" class="eyebrow text-[#4da3ff]/70 hover:text-[#4da3ff] transition-colors flex items-center gap-1.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Blog
        </a>
        {post.publishedAt && (
          <>
            <span class="text-white/20">·</span>
            <span class="eyebrow text-white/40">{fmt(post.publishedAt)}</span>
          </>
        )}
      </div>

      <h1 class="text-white mb-5" style="font-family: var(--font-poppins), system-ui, sans-serif; font-size: clamp(26px, 4.5vw, 56px); font-weight: 700; line-height: 1.08; letter-spacing: -0.03em; max-width: 820px;">
        {post.title}
      </h1>

      {post.excerpt && (
        <p class="text-[17px] text-white/55 leading-relaxed max-w-2xl">{post.excerpt}</p>
      )}
    </div>
  </section>

  <!-- Main content -->
  <div data-navbar="light" class="bg-white">

    {/* Featured image */}
    {post.mainImage && (
      <div class="max-w-4xl mx-auto px-6 -mt-1 pt-10">
        <img
          src={urlFor(post.mainImage).width(1200).height(600).fit('crop').url()}
          alt={post.mainImage.alt || post.title}
          class="w-full rounded-2xl object-cover aspect-[2/1] shadow-[0_8px_40px_rgba(29,0,132,0.12)]"
        />
      </div>
    )}

    {/* 3-col layout */}
    <div class="max-w-[1200px] mx-auto px-6 py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[56px_1fr_200px] xl:grid-cols-[72px_1fr_220px] gap-0 lg:gap-12 xl:gap-16">

        {/* Share — left */}
        <div class="hidden lg:block self-stretch">
          <BlogShare title={post.title} client:load />
        </div>

        {/* Article — center */}
        <article class="blog-article min-w-0">
          {post.body && (
            <div class="prose-nawar">
              <PortableText value={post.body} />
            </div>
          )}

          {/* Mobile share */}
          <div class="mt-12 pt-8 border-t border-[#DDE6F5] lg:hidden">
            <p class="text-[12px] font-semibold text-[#9CA3AF] uppercase tracking-[0.14em] mb-4">Compartir</p>
            <div class="flex items-center gap-3">
              <BlogShare title={post.title} client:load />
            </div>
          </div>

          {/* Back link */}
          <div class="mt-12 pt-8 border-t border-[#DDE6F5]">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 text-[14px] font-medium text-[#5A6480] hover:text-[#1D0084] transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
              </svg>
              Volver al blog
            </a>
          </div>
        </article>

        {/* TOC — right */}
        <div class="hidden lg:block self-stretch">
          <BlogTOC client:load />
        </div>

      </div>
    </div>
  </div>

  {/* ── Artículos relacionados ── */}
  {relatedPosts.length > 0 && (
    <section data-navbar="light" class="related-section">
      <div class="related-wrap">
        <header class="related-header">
          <h2 class="related-heading">Artículos relacionados</h2>
        </header>

        <div class="related-grid">
          {relatedPosts.map((p: any, i: number) => {
            const cat = p.category ? CATEGORY_META[p.category] : null
            const mins = Math.max(1, Number(p.readingMinutes) || 3)
            return (
              <a href={`/blog/${p.slug}`} class="bp-card" style={`--card-delay:${0.04 + i * 0.06}s`}>
                {p.mainImage ? (
                  <div class="bp-img">
                    <img
                      src={urlFor(p.mainImage).width(600).height(360).fit('crop').quality(80).url()}
                      alt={p.mainImage.alt || p.title}
                      loading="lazy"
                      width="600" height="360"
                    />
                  </div>
                ) : (
                  <div class="bp-img bp-img-fallback">🇳🇱</div>
                )}
                <div class="bp-body">
                  <div class="bp-meta">
                    {cat
                      ? <span class={`bp-chip ${cat.className}`}>{cat.label}</span>
                      : <span />}
                    <span class="bp-reading">
                      <svg class="bp-reading-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="8" cy="8" r="6.25"/>
                        <path d="M8 4.5V8l2.25 1.25"/>
                      </svg>
                      {mins} min lectura
                    </span>
                  </div>
                  <h3 class="bp-title">{p.title}</h3>
                  {p.publishedAt && <p class="bp-date">{fmt(p.publishedAt)}</p>}
                  {p.excerpt && <p class="bp-excerpt">{p.excerpt}</p>}
                  <span class="bp-read">
                    Leer artículo
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 8h10M9 4l4 4-4 4"/>
                    </svg>
                  </span>
                </div>
              </a>
            )
          })}
        </div>
      </div>
    </section>
  )}

  <FooterNuevo />
</Layout>

<style>
  /* Blog prose styles */
  :global(.prose-nawar) {
    color: #374151;
    font-size: 17px;
    line-height: 1.75;
    max-width: 680px;
  }
  :global(.prose-nawar h2) {
    font-family: var(--font-poppins), system-ui, sans-serif;
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 700;
    color: #1D0084;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  :global(.prose-nawar h3) {
    font-family: var(--font-poppins), system-ui, sans-serif;
    font-size: clamp(17px, 2vw, 21px);
    font-weight: 600;
    color: #1D0084;
    letter-spacing: -0.015em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  :global(.prose-nawar p) {
    margin-bottom: 1.25rem;
  }
  :global(.prose-nawar a) {
    color: #025dc7;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  :global(.prose-nawar a:hover) { color: #1D0084; }
  :global(.prose-nawar strong) { color: #1D0084; font-weight: 600; }
  :global(.prose-nawar ul) {
    list-style: none;
    padding: 0;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  :global(.prose-nawar ul li) {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
  }
  :global(.prose-nawar ul li::before) {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4da3ff;
    margin-top: 0.6em;
    flex-shrink: 0;
  }
  :global(.prose-nawar ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  :global(.prose-nawar ol li) { color: #374151; }
  :global(.prose-nawar blockquote) {
    border-left: 3px solid #4da3ff;
    padding: 1rem 1.25rem;
    background: #F0F5FF;
    border-radius: 0 12px 12px 0;
    margin: 1.5rem 0;
    color: #1D0084;
    font-style: italic;
  }
  :global(.prose-nawar code) {
    font-family: ui-monospace, monospace;
    font-size: 0.88em;
    background: #F0F5FF;
    color: #025dc7;
    padding: 0.15em 0.4em;
    border-radius: 5px;
  }
  :global(.prose-nawar pre) {
    background: #0C0C1E;
    border-radius: 14px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  :global(.prose-nawar pre code) {
    background: none;
    color: #e0f2ff;
    padding: 0;
  }
  :global(.prose-nawar img) {
    border-radius: 14px;
    margin: 1.5rem 0;
    width: 100%;
  }
  :global(.prose-nawar hr) {
    border: none;
    border-top: 1px solid #DDE6F5;
    margin: 2.5rem 0;
  }

  /* ── Artículos relacionados ── */
  .related-section {
    background: #F0F5FF;
    padding: 72px 0 88px;
    border-top: 1px solid #DDE6F5;
  }
  .related-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .related-header { margin-bottom: 32px; }
  .related-heading {
    font-family: var(--font-poppins), system-ui, sans-serif;
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 700;
    color: #1D0084;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* Card blanca (compartida con blog index) */
  .bp-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    background: #FFFFFF;
    border: 1px solid #E5EAF2;
    box-shadow:
      0 1px 2px rgba(29,0,132,0.04),
      0 6px 20px rgba(29,0,132,0.05);
    transition: transform .22s ease-out, box-shadow .22s ease-out, border-color .22s ease-out;
    opacity: 0;
    transform: translateY(14px);
    animation: bp-in .55s cubic-bezier(.18,.84,.29,.99) var(--card-delay, 0s) forwards;
  }
  @keyframes bp-in { to { opacity: 1; transform: translateY(0); } }
  .bp-card:hover {
    transform: translateY(-3px);
    border-color: #CFDDF4;
    box-shadow:
      0 2px 4px rgba(29,0,132,0.05),
      0 14px 36px rgba(29,0,132,0.10);
  }

  .bp-img {
    overflow: hidden;
    flex-shrink: 0;
    aspect-ratio: 16 / 9;
    background: #F0F5FF;
  }
  .bp-img img {
    display: block;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .35s ease-out;
  }
  .bp-card:hover .bp-img img { transform: scale(1.035); }
  .bp-img-fallback {
    display: flex; align-items: center; justify-content: center;
    font-size: 48px;
  }

  .bp-body {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .bp-meta {
    display: flex; align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .bp-reading {
    display: inline-flex; align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 500;
    color: #7A8599;
    white-space: nowrap;
  }
  .bp-reading-icon {
    width: 13px; height: 13px;
    flex-shrink: 0;
    color: #9CA3AF;
  }

  .bp-chip {
    display: inline-flex; align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    white-space: nowrap;
    border: 1px solid transparent;
  }
  .bp-chip--inbu { background: #DBEAFE; color: #1D4ED8; border-color: #BFDBFE; }
  .bp-chip--cult { background: #FEF3C7; color: #B45309; border-color: #FDE68A; }
  .bp-chip--voca { background: #D1FAE5; color: #047857; border-color: #A7F3D0; }
  .bp-chip--pron { background: #FDF2F8; color: #BE185D; border-color: #FBCFE8; }

  .bp-date {
    font-size: 12.5px;
    color: #7A8599;
    font-weight: 500;
  }
  .bp-title {
    margin: 0;
    font-size: 19px;
    font-weight: 700;
    line-height: 1.3;
    color: #1D0084;
    font-family: var(--font-poppins), system-ui, sans-serif;
    letter-spacing: -0.015em;
  }
  .bp-excerpt {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    color: #4B5563;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bp-read {
    margin-top: 2px;
    font-size: 13px;
    font-weight: 600;
    color: #1D0084;
    display: inline-flex; align-items: center; gap: 6px;
    transition: gap .2s ease-out;
  }
  .bp-read svg { width: 14px; height: 14px; transition: transform .2s ease-out; }
  .bp-card:hover .bp-read { gap: 9px; }
  .bp-card:hover .bp-read svg { transform: translateX(2px); }

  @media (max-width: 1024px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .related-wrap { padding: 0 24px; }
  }
  @media (max-width: 640px) {
    .related-section { padding: 48px 0 60px; }
    .related-grid { grid-template-columns: 1fr; gap: 16px; }
    .related-wrap { padding: 0 16px; }
    .bp-title { font-size: 18px; }
  }
</style>
