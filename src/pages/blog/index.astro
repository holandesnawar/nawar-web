---
import { sanityClient } from 'sanity:client'
import Layout from '../../layouts/Layout.astro'
import NavbarLanding from '../../components/NavbarLanding'
import FooterNuevo from '../../components/FooterNuevo.astro'
import { POSTS_QUERY } from '../../sanity/queries'
import '../../styles/nawar-sections.css'
import imageUrlBuilder from '@sanity/image-url'

export const prerender = false

const posts = await sanityClient.fetch(POSTS_QUERY)
const builder = imageUrlBuilder(sanityClient)
const urlFor = (source: any) => builder.image(source)

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })
---

<Layout
  title="Blog — Holandés Nawar"
  description="Artículos sobre el aprendizaje del neerlandés para hispanohablantes. Gramática, cultura, consejos y más."
>
  <NavbarLanding client:load />

  <!-- Hero -->
  <section data-navbar="dark" class="relative bg-[#1D0084] overflow-hidden pt-36 pb-24">
    <div aria-hidden class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px]"
           style="background: radial-gradient(ellipse at center top, rgba(11,109,240,0.38) 0%, transparent 65%)"/>
    </div>
    <div aria-hidden class="absolute inset-0 dots-dark pointer-events-none" />
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#025dc7] text-[#e0f2ff] eyebrow mb-6">
        <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Recursos gratuitos
      </span>
      <h1 class="title text-white mb-4">
        <span class="text-gradient-white">Aprende más sobre</span><br/>
        <span class="text-[#4da3ff]" style="color: #4da3ff; -webkit-text-fill-color: #4da3ff;">el neerlandés</span>
      </h1>
      <p class="text-[18px] text-white/55 leading-relaxed max-w-lg mx-auto">
        Gramática, cultura, consejos de aprendizaje y todo lo que necesitas saber desde el español.
      </p>
    </div>
  </section>

  <!-- Posts grid con nuevo diseño glass -->
  <section data-navbar="light" class="blog-page-section">
    <div class="blog-page-wrap">

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <div class="text-5xl mb-4">📝</div>
          <p class="text-[18px] text-[#9CA3AF] font-medium">Pronto llegan los primeros artículos.</p>
        </div>
      ) : (
        <div class="bp-grid">
          {posts.map((post: any, i: number) => (
            <a href={`/blog/${post.slug}`} class="bp-card" style={`--card-delay:${0.06 + i * 0.10}s`}>
              {post.mainImage ? (
                <div class="bp-img">
                  <img
                    src={urlFor(post.mainImage).width(600).height(340).fit('crop').quality(80).url()}
                    alt={post.mainImage.alt || post.title}
                    loading="lazy"
                    width="600" height="340"
                  />
                </div>
              ) : (
                <div class="bp-img bp-img-fallback">🇳🇱</div>
              )}
              <div class="bp-body">
                <h3 class="bp-title">{post.title}</h3>
                {post.publishedAt && <p class="bp-date">{fmt(post.publishedAt)}</p>}
                {post.excerpt && <p class="bp-excerpt">{post.excerpt}</p>}
                <span class="bp-read">
                  Leer artículo
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 8h10M9 4l4 4-4 4"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

  <FooterNuevo />
</Layout>

<style>
/* ── Section ── */
.blog-page-section {
  background: #F0F5FF;
  padding: 64px 0 80px;
  position: relative;
}
.blog-page-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}

/* ── Grid 3 cols ── */
.bp-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

/* ── Card glass azul oscuro marca ── */
.bp-card {
  position: relative;
  display: flex;
  flex-direction: column;
  border-radius: 18px;
  overflow: hidden;
  isolation: isolate;
  text-decoration: none;
  color: #fff;
  background:
    radial-gradient(ellipse at 25% -15%, rgba(11,109,240,0.55) 0%, transparent 58%),
    #1D0084;
  border: 1px solid rgba(255,255,255,0.14);
  box-shadow: 0 8px 32px rgba(29,0,132,0.25);
  transition: transform .2s ease-out, box-shadow .2s ease-out, border-color .2s;
  opacity: 0;
  transform: translateY(20px);
  animation: bp-in .65s cubic-bezier(.18,.84,.29,.99) var(--card-delay, 0s) forwards;
}
.bp-card::before {
  content: "";
  position: absolute; inset: 0; pointer-events: none; border-radius: inherit;
  background: linear-gradient(145deg, rgba(255,255,255,.14), rgba(255,255,255,0) 40%);
  mix-blend-mode: screen; opacity: .45;
}
@keyframes bp-in { to { opacity:1; transform:translateY(0); } }
.bp-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255,255,255,0.22);
}

/* ── Image ── */
.bp-img {
  overflow: hidden;
  border-radius: 14px;
  margin: 14px 14px 0;
  flex-shrink: 0;
}
.bp-img img {
  display: block; width: 100%; height: auto;
  border-radius: 14px;
  transition: transform .2s ease-out;
}
.bp-card:hover .bp-img img { transform: scale(1.04); }
.bp-img-fallback {
  height: 160px;
  display: flex; align-items: center; justify-content: center;
  font-size: 48px; background: rgba(255,255,255,0.06);
}

/* ── Body ── */
.bp-body {
  padding: 16px 20px 20px;
  display: flex; flex-direction: column; gap: 6px; flex: 1;
}
.bp-title {
  margin: 0; font-size: 20px; font-weight: 700; line-height: 1.3;
  font-family: var(--font-poppins), system-ui, sans-serif;
}
.bp-date {
  font-size: 12.5px; color: rgba(220,235,255,0.72); margin: 0;
}
.bp-excerpt {
  font-size: 13.5px; font-weight: 500; line-height: 1.65;
  color: rgba(222,234,255,0.90); margin: 4px 0 0;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.bp-read {
  margin-top: 12px;
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,0.85);
  display: inline-flex; align-items: center; gap: 5px;
}
.bp-read svg { width: 14px; height: 14px; }
.bp-card:hover .bp-read { color: #fff; }

/* ── Responsive ── */
@media (max-width: 1024px) {
  .bp-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .blog-page-wrap { padding: 0 24px; }
}
@media (max-width: 640px) {
  .blog-page-section { padding: 40px 0 56px; }
  .bp-grid { grid-template-columns: 1fr; gap: 16px; }
  .blog-page-wrap { padding: 0 16px; }
  .bp-title { font-size: 18px; }
}
</style>
