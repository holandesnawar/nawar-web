---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import NavbarLanding from '../../components/NavbarLanding'
import FooterNuevo from '../../components/FooterNuevo.astro'
import '../../styles/nawar-sections.css'

export const prerender = true

const entries = await getCollection('blog')
const posts = entries
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((e) => ({
    _id: e.id,
    title: e.data.title,
    slug: e.slug,
    publishedAt: e.data.publishedAt.toISOString(),
    excerpt: e.data.excerpt,
    category: e.data.category,
    mainImage: e.data.mainImage,
    readingMinutes: e.data.readingMinutes,
  }))

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })

const CATEGORY_META: Record<string, { label: string; className: string }> = {
  inburgering:   { label: 'Inburgering',   className: 'bp-chip--inbu' },
  cultura:       { label: 'Cultura',       className: 'bp-chip--cult' },
  vocabulario:   { label: 'Vocabulario',   className: 'bp-chip--voca' },
  pronunciacion: { label: 'Pronunciación', className: 'bp-chip--pron' },
}

const FILTERS = [
  { value: 'todos',         label: 'Todos' },
  { value: 'inburgering',   label: 'Inburgering' },
  { value: 'cultura',       label: 'Cultura' },
  { value: 'vocabulario',   label: 'Vocabulario' },
  { value: 'pronunciacion', label: 'Pronunciación' },
]
---

<Layout
  title="Blog — Holandés Nawar"
  description="Artículos sobre el aprendizaje del neerlandés para hispanohablantes. Gramática, cultura, consejos y más."
>
  <NavbarLanding client:load />

  <!-- Hero -->
  <section data-navbar="dark" class="relative bg-[#1D0084] overflow-hidden pt-36 pb-24">
    <div aria-hidden class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px]"
           style="background: radial-gradient(ellipse at center top, rgba(11,109,240,0.38) 0%, transparent 65%)"/>
    </div>
    <div aria-hidden class="absolute inset-0 dots-dark pointer-events-none" />
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <span class="inline-flex items-center px-4 py-1.5 rounded-full bg-[#025dc7] text-[#e0f2ff] eyebrow mb-6">
        Nuestros artículos
      </span>
      <h1 class="title text-white mb-4">
        <span class="text-gradient-white">Aprende más sobre</span><br/>
        <span class="text-[#4da3ff]" style="color: #4da3ff; -webkit-text-fill-color: #4da3ff;">el neerlandés</span>
      </h1>
      <p class="text-[18px] text-white/55 leading-relaxed max-w-lg mx-auto mb-8">
        Gramática, cultura, consejos de aprendizaje y todo lo que necesitas saber desde el español.
      </p>

      <!-- Buscador -->
      <form class="bp-search" role="search" onsubmit="return false;">
        <svg class="bp-search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="9" r="6.25"/>
          <path d="m14 14 3.5 3.5"/>
        </svg>
        <input
          id="bp-search-input"
          type="search"
          placeholder="Buscar artículo…"
          aria-label="Buscar artículos"
          autocomplete="off"
        />
        <button type="button" id="bp-search-clear" class="bp-search-clear" aria-label="Limpiar búsqueda" hidden>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4l8 8M12 4l-8 8"/>
          </svg>
        </button>
      </form>
    </div>
  </section>

  <!-- Posts -->
  <section data-navbar="light" class="blog-page-section">
    <div class="blog-page-wrap">

      {posts.length === 0 ? (
        <div class="text-center py-20">
          <div class="text-5xl mb-4">📝</div>
          <p class="text-[18px] text-[#9CA3AF] font-medium">Pronto llegan los primeros artículos.</p>
        </div>
      ) : (
        <>
          <!-- Filtros -->
          <div class="bp-filters" role="tablist" aria-label="Filtrar por categoría">
            {FILTERS.map((f, i) => (
              <button
                type="button"
                class={`bp-filter ${i === 0 ? 'is-active' : ''}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                data-filter={f.value}
              >
                {f.label}
              </button>
            ))}
          </div>

          <!-- Grid -->
          <div class="bp-grid" id="bp-grid">
            {posts.map((post: any, i: number) => {
              const cat = post.category ? CATEGORY_META[post.category] : null
              const mins = Math.max(1, Number(post.readingMinutes) || 3)
              const searchText = [post.title, post.excerpt].filter(Boolean).join(' ').toLowerCase()
              return (
                <a
                  href={`/blog/${post.slug}`}
                  class="bp-card"
                  style={`--card-delay:${0.04 + i * 0.05}s`}
                  data-category={post.category || ''}
                  data-search={searchText}
                >
                  {post.mainImage?.src ? (
                    <div class="bp-img">
                      <img
                        src={post.mainImage.src}
                        alt={post.mainImage.alt || post.title}
                        loading={i < 3 ? 'eager' : 'lazy'}
                        width="600" height="360"
                      />
                    </div>
                  ) : (
                    <div class="bp-img bp-img-fallback">🇳🇱</div>
                  )}
                  <div class="bp-body">
                    <div class="bp-meta">
                      {cat
                        ? <span class={`bp-chip ${cat.className}`}>{cat.label}</span>
                        : <span />}
                      <span class="bp-reading">
                        <svg class="bp-reading-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="8" cy="8" r="6.25"/>
                          <path d="M8 4.5V8l2.25 1.25"/>
                        </svg>
                        {mins} min lectura
                      </span>
                    </div>
                    <h3 class="bp-title">{post.title}</h3>
                    {post.publishedAt && <p class="bp-date">{fmt(post.publishedAt)}</p>}
                    {post.excerpt && <p class="bp-excerpt">{post.excerpt}</p>}
                    <span class="bp-read">
                      Leer artículo
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 8h10M9 4l4 4-4 4"/>
                      </svg>
                    </span>
                  </div>
                </a>
              )
            })}
          </div>

          <!-- Estado vacío (sin resultados) -->
          <div id="bp-empty" class="bp-empty" hidden>
            <div class="bp-empty-emoji">🔍</div>
            <p class="bp-empty-title">No encontramos artículos</p>
            <p class="bp-empty-sub">Prueba con otra búsqueda o categoría.</p>
          </div>
        </>
      )}

    </div>
  </section>

  <FooterNuevo />
</Layout>

<script is:inline>
  (function () {
    const grid    = document.getElementById('bp-grid');
    const empty   = document.getElementById('bp-empty');
    const input   = document.getElementById('bp-search-input');
    const clear   = document.getElementById('bp-search-clear');
    if (!grid) return;

    const cards   = Array.from(grid.querySelectorAll('.bp-card'));
    const chips   = Array.from(document.querySelectorAll('.bp-filter'));
    let activeCat = 'todos';
    let query     = '';

    function normalize(s) {
      return (s || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');
    }

    function apply() {
      const q = normalize(query.trim());
      let visible = 0;
      cards.forEach((card) => {
        const cat = card.getAttribute('data-category') || '';
        const txt = normalize(card.getAttribute('data-search') || '');
        const matchCat = activeCat === 'todos' || cat === activeCat;
        const matchQ   = !q || txt.includes(q);
        const show     = matchCat && matchQ;
        card.hidden = !show;
        if (show) visible++;
      });
      if (empty) empty.hidden = visible > 0;
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const v = chip.getAttribute('data-filter');
        if (!v) return;
        activeCat = v;
        chips.forEach((c) => {
          const isActive = c === chip;
          c.classList.toggle('is-active', isActive);
          c.setAttribute('aria-selected', isActive ? 'true' : 'false');
        });
        apply();
      });
    });

    if (input) {
      input.addEventListener('input', (e) => {
        query = e.target.value || '';
        if (clear) clear.hidden = query.length === 0;
        apply();
      });
    }
    if (clear) {
      clear.addEventListener('click', () => {
        if (input) input.value = '';
        query = '';
        clear.hidden = true;
        apply();
        input && input.focus();
      });
    }
  })();
</script>

<style>
/* ── Search bar en banner ── */
.bp-search {
  position: relative;
  max-width: 580px;
  margin: 0 auto;
}
.bp-search-icon {
  position: absolute;
  top: 50%;
  left: 20px;
  transform: translateY(-50%);
  width: 20px; height: 20px;
  color: rgba(255,255,255,0.9);
  pointer-events: none;
  transition: color .2s;
  z-index: 2;
  display: block;
}
.bp-search-icon circle,
.bp-search-icon path { fill: none; stroke: currentColor; }
.bp-search input {
  width: 100%;
  padding: 18px 52px 18px 54px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.28);
  border-radius: 16px;
  color: #fff;
  font-size: 16px;
  font-family: inherit;
  line-height: 1;
  outline: none;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  transition: border-color .2s, background .2s, box-shadow .2s;
}
.bp-search input::placeholder { color: rgba(255,255,255,0.65); }
.bp-search input::-webkit-search-cancel-button { display: none; }
.bp-search input:hover {
  border-color: rgba(255,255,255,0.4);
  background: rgba(255,255,255,0.15);
}
.bp-search input:focus {
  border-color: #4da3ff;
  background: rgba(255,255,255,0.18);
  box-shadow: 0 0 0 4px rgba(77,163,255,0.22);
}
.bp-search input:focus + .bp-search-icon,
.bp-search:focus-within .bp-search-icon { color: #fff; }
.bp-search-clear {
  position: absolute;
  top: 50%;
  right: 14px;
  transform: translateY(-50%);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px; height: 28px;
  background: transparent;
  border: none;
  padding: 0;
  color: rgba(255,255,255,0.7);
  cursor: pointer;
  transition: color .15s, transform .15s;
}
.bp-search-clear:hover {
  color: #fff;
  transform: translateY(-50%) scale(1.08);
}
.bp-search-clear svg { width: 16px; height: 16px; }

/* ── Section ── */
.blog-page-section {
  background: #F0F5FF;
  padding: 56px 0 80px;
  position: relative;
}
.blog-page-wrap {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}

/* ── Filter pills ── */
.bp-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 36px;
}
.bp-filter {
  display: inline-flex;
  align-items: center;
  padding: 9px 18px;
  border-radius: 999px;
  background: #FFFFFF;
  border: 1px solid #DDE6F5;
  color: #475569;
  font-size: 14px;
  font-weight: 600;
  font-family: inherit;
  line-height: 1;
  cursor: pointer;
  transition: background .18s ease-out, color .18s ease-out, border-color .18s ease-out;
}
.bp-filter:hover {
  color: #1D0084;
  border-color: #4da3ff;
}
.bp-filter.is-active {
  background:
    radial-gradient(ellipse at 50% 0%, rgba(11,109,240,0.55) 0%, transparent 75%),
    #1D0084;
  border-color: #1D0084;
  color: #fff;
}

/* ── Grid 3 cols ── */
.bp-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

/* ── Card blanca profesional ── */
.bp-card {
  position: relative;
  display: flex;
  flex-direction: column;
  border-radius: 18px;
  overflow: hidden;
  text-decoration: none;
  background: #FFFFFF;
  border: 1px solid #E5EAF2;
  box-shadow:
    0 1px 2px rgba(29,0,132,0.04),
    0 6px 20px rgba(29,0,132,0.05);
  transition: transform .22s ease-out, box-shadow .22s ease-out, border-color .22s ease-out;
  opacity: 0;
  transform: translateY(14px);
  animation: bp-in .55s cubic-bezier(.18,.84,.29,.99) var(--card-delay, 0s) forwards;
}
@keyframes bp-in { to { opacity: 1; transform: translateY(0); } }
.bp-card:hover {
  transform: translateY(-3px);
  border-color: #CFDDF4;
  box-shadow:
    0 2px 4px rgba(29,0,132,0.05),
    0 14px 36px rgba(29,0,132,0.10);
}
.bp-card[hidden] { display: none; }

/* ── Image ── */
.bp-img {
  overflow: hidden;
  flex-shrink: 0;
  aspect-ratio: 16 / 9;
  background: #F0F5FF;
}
.bp-img img {
  display: block;
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .35s ease-out;
}
.bp-card:hover .bp-img img { transform: scale(1.035); }
.bp-img-fallback {
  display: flex; align-items: center; justify-content: center;
  font-size: 48px;
}

/* ── Body ── */
.bp-body {
  padding: 18px 20px 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}
.bp-meta {
  display: flex; align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.bp-reading {
  display: inline-flex; align-items: center;
  gap: 5px;
  font-size: 12px;
  font-weight: 500;
  color: #7A8599;
  white-space: nowrap;
}
.bp-reading-icon {
  width: 13px; height: 13px;
  flex-shrink: 0;
  color: #9CA3AF;
}

/* ── Category chips ── */
.bp-chip {
  display: inline-flex; align-items: center;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.02em;
  line-height: 1;
  white-space: nowrap;
  border: 1px solid transparent;
}
.bp-chip--inbu { background: #DBEAFE; color: #1D4ED8; border-color: #BFDBFE; }
.bp-chip--cult { background: #FEF3C7; color: #B45309; border-color: #FDE68A; }
.bp-chip--voca { background: #D1FAE5; color: #047857; border-color: #A7F3D0; }
.bp-chip--pron { background: #FDF2F8; color: #BE185D; border-color: #FBCFE8; }

.bp-date {
  font-size: 12.5px;
  color: #7A8599;
  font-weight: 500;
  margin: 0;
}
.bp-title {
  margin: 0;
  font-size: 19px;
  font-weight: 700;
  line-height: 1.3;
  color: #1D0084;
  font-family: var(--font-poppins), system-ui, sans-serif;
  letter-spacing: -0.015em;
}
.bp-excerpt {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.6;
  color: #4B5563;
  margin: 0;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.bp-read {
  margin-top: 2px;
  font-size: 13px;
  font-weight: 600;
  color: #1D0084;
  display: inline-flex; align-items: center; gap: 6px;
  transition: gap .2s ease-out;
}
.bp-read svg { width: 14px; height: 14px; transition: transform .2s ease-out; }
.bp-card:hover .bp-read { gap: 9px; }
.bp-card:hover .bp-read svg { transform: translateX(2px); }

/* ── Empty state ── */
.bp-empty {
  text-align: center;
  padding: 72px 24px;
}
.bp-empty-emoji { font-size: 48px; margin-bottom: 12px; }
.bp-empty-title {
  font-size: 18px; font-weight: 700; color: #1D0084;
  margin: 0 0 4px;
  font-family: var(--font-poppins), system-ui, sans-serif;
}
.bp-empty-sub {
  font-size: 14.5px; color: #64748B;
  margin: 0;
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .bp-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .blog-page-wrap { padding: 0 24px; }
}
@media (max-width: 640px) {
  .blog-page-section { padding: 40px 0 56px; }
  .bp-grid { grid-template-columns: 1fr; gap: 16px; }
  .blog-page-wrap { padding: 0 24px; }
  .bp-title { font-size: 18px; }
  .bp-filters { gap: 8px; margin-bottom: 28px; }
  .bp-filter { padding: 8px 14px; font-size: 13px; }
  .bp-search input { font-size: 15px; padding: 15px 46px 15px 48px; }
}
</style>
