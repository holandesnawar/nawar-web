---
import Layout from '../layouts/Layout.astro'
import NavbarLanding from '../components/NavbarLanding'
import FooterNuevo from '../components/FooterNuevo.astro'
import '../styles/nawar-sections.css'

export const prerender = true

const verticales = [
  {
    icon: '📰',
    name: 'Nawar Noticias',
    tagline: 'Una noticia real, cada día.',
    desc: 'Cada día una noticia de los Países Bajos en neerlandés y español, con audio tipo podcast. Aprendes con lo que está pasando hoy mismo en el país donde vives.',
    free: '1 noticia a la semana en neerlandés y español por email',
    plus: 'Noticia diaria en neerlandés y español + audio tipo podcast',
  },
  {
    icon: '🎮',
    name: 'Nawar Juegos',
    tagline: 'Crea el hábito que nunca tuviste.',
    desc: 'Juegos ilimitados creados a partir de las noticias del día. Practicas el vocabulario nuevo y la gramática real que acabas de leer, sin sentir que estudias.',
    free: '1 juego básico al día',
    plus: 'Juegos ilimitados sobre cada noticia, con vocabulario y gramática real',
  },
  {
    icon: '🏫',
    name: 'Nawar Clases',
    tagline: 'Profesor experto en hispanohablantes.',
    desc: 'Una clase grupal en vivo cada semana con un profesor formado específicamente para hispanohablantes. Si el grupo supera 30 alumnos, se abre otro grupo. Y todas las clases anteriores quedan grabadas desde la primera.',
    free: 'Resumen texto de 1 clase por semana',
    plus: 'Clase grupal en vivo semanal + clases anteriores grabadas desde la primera',
  },
  {
    icon: '🤝',
    name: 'Nawar Comunidad',
    tagline: 'Tu gente hispana en Países Bajos.',
    desc: 'Comunidad privada de hispanohablantes en los Países Bajos. Resuelves dudas en español, compartes recursos con gente que entiende tu punto de partida y conoces a quien ya pasó por lo mismo que tú.',
    free: 'Acceso limitado al canal abierto',
    plus: 'Comunidad de hispanohablantes privada para tus dudas',
  },
]

const dolores = [
  'pagaste un curso de inburgering y aún no sabes pedir cita médica',
  'tu app te felicita por la racha de 240 días, pero el cartero te sigue mirando raro',
  'tienes amigos neerlandeses, pero todos te hablan en inglés para que "sea más fácil"',
  'llevas dos años aquí y la única frase que dices con seguridad es "ik spreek geen Nederlands"',
  'gastaste cientos de euros en clases particulares y solo aprendiste a presentarte',
]

const stats = [
  { num: '€800', label: 'el precio medio de un único nivel (A1, A2 o B1) en una academia de neerlandés en NL' },
  { num: '€65', label: 'lo que cuesta una hora de clase particular con profesor en Países Bajos' },
  { num: '83%', label: 'de hispanohablantes en NL abandonan el neerlandés durante el primer año' },
]
---

<Layout
  title="Nawar Plus | Aprender neerlandés sin que cueste un riñón"
  description="Nawar Plus, la suscripción que hace accesible el neerlandés para cualquier hispanohablante. Noticias diarias, juegos, clase semanal en vivo, comunidad y eventos. Cancelable cuando quieras."
  keywords="Nawar Plus, suscripción neerlandés, aprender holandés barato, clases neerlandés online, comunidad hispanohablantes Países Bajos"
>
  <NavbarLanding client:load />

  <!-- ════════════════════════════════════════════
       1. HERO — Logo + dolor (sin precios)
  ════════════════════════════════════════════ -->
  <section class="np-hero" data-navbar="dark">
    <div class="np-hero-glow1" aria-hidden="true"></div>
    <div class="np-hero-glow2" aria-hidden="true"></div>
    <div class="np-hero-grid-bg" aria-hidden="true"></div>
    <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;opacity:0.45;"></div>

    <div class="np-hero-inner">

      <!-- Logo central -->
      <div class="np-hero-logo-wrap np-anim" style="--hd:0.05s;">
        <img src="/nawar-plus-logo.png" alt="Nawar Plus" class="np-hero-logo" />
      </div>

      <!-- Título (una sola línea, sin doblar) -->
      <h1 class="np-hero-title np-anim" style="--hd:0.25s;">
        Aprender neerlandés en NL no debería sentirse así.
      </h1>

      <!-- Subtítulo dolor -->
      <p class="np-hero-sub np-anim" style="--hd:0.40s;">
        Te mudaste, hiciste el esfuerzo, pagaste el curso, descargaste tres apps, miraste vídeos de YouTube y seguiste a una neerlandesa en Instagram. <strong>Y aún así, sigues sin entender al cartero.</strong>
      </p>

      <!-- Scroll indicator -->
      <a href="#dolor" class="np-scroll-cue np-anim" style="--hd:0.55s;" aria-label="Ver más">
        <span>Te entendemos</span>
        <span class="np-scroll-line">
          <span class="np-scroll-dot"></span>
        </span>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       2. CARTA — Sticky text reveal
  ════════════════════════════════════════════ -->
  <section id="dolor" class="np-letter" data-navbar="dark">
    <div class="np-letter-glow" aria-hidden="true"></div>

    <div class="np-letter-inner">
      <div class="np-letter-sticky">
        <span class="np-eyebrow-small">Esto va para ti</span>
        <h2 class="np-letter-heading">
          Sabemos que<br>
          <span style="color:#4da3ff;">esto te suena.</span>
        </h2>
        <p class="np-letter-aside">
          Es la misma historia que se repite en cada hispanohablante que llega aquí. No es culpa tuya. El problema es el método.
        </p>
      </div>

      <ul class="np-letter-list">
        {dolores.map((d, i) => (
          <li class="np-letter-item sr-bi">
            <span class="np-letter-num">{(i + 1).toString().padStart(2, '0')}</span>
            <p class="np-letter-text">{d}.</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       3. STATS — Números que duelen
  ════════════════════════════════════════════ -->
  <section class="np-stats" data-navbar="dark">
    <div class="np-stats-grid-bg" aria-hidden="true"></div>
    <div class="inner" style="position:relative;z-index:1;">
      <div class="np-stats-header sr">
        <span class="np-eyebrow-small">Los números que nadie te cuenta</span>
        <h2 class="np-stats-title">
          <span class="text-gradient-white">Aprender neerlandés no es caro.</span><br>
          <span style="color:#4da3ff;">El sistema sí lo es.</span>
        </h2>
      </div>

      <div class="np-stats-grid">
        {stats.map((s, i) => (
          <div class="np-stat-card sr-bi" style={`transition-delay:${i * 0.08}s;`}>
            <div class="np-stat-num">{s.num}</div>
            <div class="np-stat-line"></div>
            <p class="np-stat-label">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       4. EL GIRO — Aquí entra Nawar Plus
  ════════════════════════════════════════════ -->
  <section class="np-reveal section-light" data-navbar="light">
    <div class="inner" style="position:relative;z-index:1;">
      <div class="np-reveal-content sr">
        <span class="badge-light">Por eso existe Nawar Plus</span>
        <h2 class="np-reveal-title">
          Todo lo que necesitas para hablar neerlandés,<br>
          <span class="np-reveal-highlight">en un solo sitio.</span>
        </h2>
        <p class="np-reveal-sub">
          Nawar Plus es el plan completo: noticias diarias, juegos ilimitados, clase grupal en vivo cada semana con un profesor experto en hispanohablantes, todas las clases anteriores grabadas desde la primera, y una comunidad hispanohablante real en Países Bajos. Para que el neerlandés deje de ser una tarea pendiente y se convierta en parte de tu vida.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       5. LOS 4 VERTICALES
  ════════════════════════════════════════════ -->
  <section class="section-light" data-navbar="light" style="padding-bottom: 96px;">
    <div class="inner">
      <div class="np-vert-header sr">
        <h3 class="np-vert-section-title">Lo que recibes cada día y cada semana</h3>
        <p class="np-vert-section-sub">Cuatro piezas que se complementan. Un único objetivo: que aprendas neerlandés de verdad, sin que te cueste un sueldo.</p>
      </div>

      <div class="np-vert-grid">
        {verticales.map((v, i) => (
          <div class="np-vert-card sr-bi" style={`transition-delay:${i * 0.06}s;`}>
            <div class="np-vert-icon-wrap">
              <span class="np-vert-icon">{v.icon}</span>
            </div>
            <h4 class="np-vert-name">{v.name}</h4>
            <p class="np-vert-tagline">{v.tagline}</p>
            <p class="np-vert-desc">{v.desc}</p>
            <div class="np-vert-split">
              <div class="np-vert-split-row">
                <span class="np-vert-split-label np-vert-split-free">Gratis</span>
                <span class="np-vert-split-value">{v.free}</span>
              </div>
              <div class="np-vert-split-row">
                <span class="np-vert-split-label np-vert-split-plus">Plus</span>
                <span class="np-vert-split-value">{v.plus}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       6. COMPARATIVA — Plan Gratuito vs Nawar Plus
  ════════════════════════════════════════════ -->
  <section id="planes" class="np-comp" data-navbar="dark">
    <div class="np-comp-glow" aria-hidden="true"></div>
    <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></div>

    <div class="inner" style="position:relative;z-index:1;">
      <div class="np-comp-header sr">
        <span class="np-eyebrow-small">Plan gratuito vs Plus</span>
        <h2 class="np-comp-title">
          <span class="text-gradient-white">Empieza gratis.</span><br>
          <span style="color:#4da3ff;">Sube a Plus cuando quieras.</span>
        </h2>
        <p class="np-comp-sub">
          El plan gratuito sirve para crear hábito y demostrarte que el método funciona. Plus es para quien ya quiere aprender de verdad, con clase semanal en vivo, comunidad activa y una noticia diaria.
        </p>
      </div>

      <div class="np-comp-grid">

        <!-- Plan Gratuito -->
        <div class="np-comp-card np-comp-free sr-bi">
          <div class="np-comp-card-top">
            <span class="np-comp-tag">Plan Gratuito</span>
            <p class="np-comp-price">
              <span class="np-comp-amount">0€</span>
              <span class="np-comp-period">/siempre</span>
            </p>
            <p class="np-comp-desc">Crea el hábito. Demuestra el método. Sin tarjeta.</p>
          </div>
          <ul class="np-comp-list">
            <li><span class="np-tick"></span><span>1 noticia semanal en neerlandés y español por email</span></li>
            <li><span class="np-tick"></span><span>1 juego básico al día</span></li>
            <li><span class="np-tick"></span><span>Resumen texto de 1 clase por semana</span></li>
            <li><span class="np-tick"></span><span>Acceso al canal abierto de la comunidad</span></li>
            <li class="np-comp-locked"><span class="np-tick np-tick-off"></span><span>Sin clase en vivo y sin grabaciones</span></li>
          </ul>
          <a href="/lista-de-espera" class="np-comp-cta np-comp-cta-free">
            Empezar gratis
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <!-- Nawar Plus -->
        <div class="np-comp-card np-comp-plus sr-bi" style="transition-delay:0.08s;">
          <div class="np-comp-card-glow" aria-hidden="true"></div>
          <span class="np-comp-ribbon">Recomendado</span>
          <div class="np-comp-card-top">
            <span class="np-comp-tag np-comp-tag-plus">Nawar Plus</span>
            <p class="np-comp-price">
              <span class="np-comp-amount" style="color:#fff;">30€</span>
              <span class="np-comp-period" style="color:rgba(255,255,255,0.6);">/mes</span>
            </p>
            <p class="np-comp-desc" style="color:rgba(255,255,255,0.85);">El plan completo. Por lo que cuesta un café al día.</p>
          </div>
          <ul class="np-comp-list">
            <li style="color:#fff;"><span class="np-tick np-tick-plus"></span><span><strong>Noticia diaria</strong> en neerlandés y español + audio tipo podcast</span></li>
            <li style="color:#fff;"><span class="np-tick np-tick-plus"></span><span><strong>Juegos ilimitados</strong> sobre las noticias con vocabulario nuevo y gramática real</span></li>
            <li style="color:#fff;"><span class="np-tick np-tick-plus"></span><span><strong>Clase grupal en vivo semanal</strong> con profesor experto en hispanohablantes</span></li>
            <li style="color:#fff;"><span class="np-tick np-tick-plus"></span><span><strong>Clases anteriores grabadas</strong> desde la primera</span></li>
            <li style="color:#fff;"><span class="np-tick np-tick-plus"></span><span><strong>Comunidad de hispanohablantes</strong> privada para tus dudas</span></li>
          </ul>
          <a href="/lista-de-espera" class="np-comp-cta np-comp-cta-plus">
            Apúntate a Plus · 30€/mes
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <p class="np-comp-cancel">Cancela cuando quieras · sin permanencia</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       7. PRECIO HONESTO — Por qué 30€
  ════════════════════════════════════════════ -->
  <section class="np-price" data-navbar="dark">
    <div class="np-price-glow" aria-hidden="true"></div>
    <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;opacity:0.4;"></div>

    <div class="inner" style="position:relative;z-index:1;">
      <div class="np-price-header sr">
        <span class="np-eyebrow-small">El precio honesto</span>
        <h2 class="np-price-title">
          <span class="text-gradient-white">30€ al mes.</span><br>
          <span style="color:#4da3ff;">Punto.</span>
        </h2>
        <p class="np-price-sub">
          Sabemos que es ridículamente barato. Una academia en NL cobra unos €800 solo por el nivel A1, y una hora suelta con profesor particular ronda los €65. Nosotros incluimos clase semanal en vivo, noticia diaria, juegos ilimitados y comunidad hispanohablante privada por menos de 1€ al día. Porque queremos que aprender neerlandés sea accesible para cualquier hispano. No solo para quien puede pagar €800 por nivel.
        </p>
      </div>

      <div class="np-price-compare sr">
        <div class="np-price-col">
          <p class="np-price-col-label">Curso A1 en academia</p>
          <p class="np-price-col-amount">~€800</p>
          <p class="np-price-col-detail">Solo un nivel · sin comunidad · sin grabaciones</p>
        </div>
        <div class="np-price-col">
          <p class="np-price-col-label">Profesor particular</p>
          <p class="np-price-col-amount">~€65/h</p>
          <p class="np-price-col-detail">Una hora suelta · sin material · sin grupo</p>
        </div>
        <div class="np-price-col np-price-col-featured">
          <span class="np-price-best">Mejor opción</span>
          <p class="np-price-col-label" style="color:#fff;">Nawar Plus completo</p>
          <p class="np-price-col-amount" style="color:#4da3ff;">30€/mes</p>
          <p class="np-price-col-detail" style="color:rgba(255,255,255,0.85);">Todo incluido cada mes, cancelable cuando quieras</p>
        </div>
      </div>

      <p class="np-price-coffee sr">
        Es <strong style="color:#4da3ff;">menos de 1€ al día</strong>. Lo mismo que un café cualquiera en Ámsterdam.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       8. MANIFIESTO + CTA FINAL
  ════════════════════════════════════════════ -->
  <section class="np-manifiesto" data-navbar="dark">
    <div class="inner">
      <div class="np-manifiesto-card sr-s">
        <span class="np-eyebrow-small" style="margin-bottom:20px;">Nuestra promesa</span>
        <h2 class="np-manifiesto-title">
          Desde Nawar creemos que aprender neerlandés<br>
          <span style="color:#4da3ff;">no debería ser un lujo.</span>
        </h2>
        <p class="np-manifiesto-text">
          Por eso construimos Nawar Plus al precio más bajo posible: 30€ al mes. No es un curso premium con tres pagos en cuotas, ni una academia con factura por nivel. Es el plan completo con todo lo que de verdad necesitas para hablar neerlandés en serio, cancelable cuando quieras.
        </p>
        <p class="np-manifiesto-text">
          Porque cada hispano que llega a Países Bajos merece la oportunidad de integrarse, trabajar y vivir aquí sin que el idioma sea la pared que lo bloquea. Esa es la misión. Eso es Nawar Plus.
        </p>
        <div class="np-manifiesto-ctas">
          <a href="/lista-de-espera" class="np-comp-cta np-comp-cta-plus" style="width:auto;padding:18px 32px;">
            Apúntate a Nawar Plus
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/nuestra-vision" class="np-cta-ghost">
            Conoce nuestra visión
          </a>
        </div>
        <p class="np-manifiesto-fineprint">
          30€/mes · cancela cuando quieras · sin permanencia · sin sorpresas
        </p>
      </div>
    </div>
  </section>

  <FooterNuevo />
</Layout>

<style>
/* ════════════════════════════════════════════
   NAWAR PLUS — Estilos
════════════════════════════════════════════ */

/* ── Load animation ── */
@keyframes np-in {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
.np-anim {
  opacity: 0;
  animation: np-in 0.85s cubic-bezier(0.22,1,0.36,1) forwards;
  animation-delay: var(--hd, 0s);
}
@keyframes np-float-y {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}
@keyframes np-glow-pulse {
  0%, 100% { opacity: 0.55; transform: scale(1); }
  50%      { opacity: 0.85; transform: scale(1.05); }
}
@keyframes np-scroll-dot {
  0%       { transform: translateY(0); opacity: 1; }
  70%      { transform: translateY(22px); opacity: 0; }
  100%     { transform: translateY(0); opacity: 0; }
}

/* ── Tipografía / utilities ── */
.np-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 7px 16px; border-radius: 9999px;
  background: rgba(77,163,255,0.10);
  border: 1px solid rgba(77,163,255,0.30);
  color: #4da3ff;
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  margin-bottom: 24px;
}
.np-eyebrow-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: #4da3ff;
  box-shadow: 0 0 8px #4da3ff;
  animation: pulse-dot 1.6s ease-in-out infinite;
}
.np-eyebrow-small {
  display: inline-block;
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: #4da3ff;
  margin-bottom: 18px;
}

/* ════════════════════════════════════════════
   1. HERO
════════════════════════════════════════════ */
.np-hero {
  background: #1D0084;
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
.np-hero-glow1 {
  position: absolute; top: -200px; right: -180px;
  width: 760px; height: 760px; border-radius: 50%;
  background: radial-gradient(circle, rgba(77,163,255,0.32) 0%, transparent 65%);
  pointer-events: none;
  animation: np-glow-pulse 8s ease-in-out infinite;
}
.np-hero-glow2 {
  position: absolute; bottom: -280px; left: -180px;
  width: 720px; height: 720px; border-radius: 50%;
  background: radial-gradient(circle, rgba(11,109,240,0.30) 0%, transparent 65%);
  pointer-events: none;
  animation: np-glow-pulse 10s ease-in-out infinite reverse;
}
.np-hero-grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(77,163,255,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(77,163,255,0.06) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse at center, #000 30%, transparent 75%);
  pointer-events: none;
}

.np-hero-inner {
  max-width: 880px;
  margin: 0 auto;
  padding: 130px 24px 80px;
  width: 100%;
  text-align: center;
  position: relative;
  z-index: 1;
}

/* Logo Plus */
.np-hero-logo-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 28px;
}
.np-hero-logo {
  display: block;
  max-width: 520px;
  width: 78vw;
  height: auto;
  filter:
    drop-shadow(0 0 32px rgba(77,163,255,0.45))
    drop-shadow(0 20px 48px rgba(0,0,0,0.55));
  animation: np-float-y 6s ease-in-out infinite;
}

.np-hero-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(30px, 4.6vw, 60px);
  font-weight: 600;
  letter-spacing: -0.028em;
  line-height: 1.15;
  margin: 0 0 24px;
  color: #fff;
  max-width: 820px;
}

.np-hero-sub {
  font-size: clamp(15px, 1.5vw, 19px);
  color: rgba(255,255,255,0.78);
  line-height: 1.7;
  max-width: 640px;
  margin: 0 auto 56px;
}
.np-hero-sub strong { color: #fff; font-weight: 600; }

/* Scroll cue */
.np-scroll-cue {
  display: inline-flex; flex-direction: column;
  align-items: center; gap: 12px;
  font-size: 11px; font-weight: 600;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  transition: color 0.25s;
}
.np-scroll-cue:hover { color: rgba(255,255,255,0.9); }
.np-scroll-line {
  position: relative;
  width: 1.5px; height: 38px;
  background: rgba(255,255,255,0.18);
  overflow: hidden;
}
.np-scroll-dot {
  position: absolute; top: 0; left: 50%;
  transform: translateX(-50%);
  width: 1.5px; height: 14px;
  background: #4da3ff;
  box-shadow: 0 0 6px rgba(77,163,255,0.7);
  animation: np-scroll-dot 1.8s cubic-bezier(0.4,0,0.2,1) infinite;
}
.np-br-desktop { display: inline; }
@media (max-width: 700px) { .np-br-desktop { display: none; } }

/* ════════════════════════════════════════════
   2. LETTER — Sticky con dolores
════════════════════════════════════════════ */
.np-letter {
  background: #1D0084;
  position: relative;
  overflow: hidden;
  padding: 120px 0 140px;
}
.np-letter-glow {
  position: absolute; top: 30%; left: -200px;
  width: 600px; height: 600px; border-radius: 50%;
  background: radial-gradient(circle, rgba(77,163,255,0.18) 0%, transparent 65%);
  pointer-events: none;
}
.np-letter-inner {
  max-width: 1152px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 1fr;
  gap: 64px;
  position: relative;
  z-index: 1;
}
@media (min-width: 900px) {
  .np-letter-inner { grid-template-columns: 0.85fr 1.15fr; gap: 80px; }
}

.np-letter-sticky {
  position: relative;
}
@media (min-width: 900px) {
  .np-letter-sticky {
    position: sticky;
    top: 120px;
    height: fit-content;
    align-self: start;
  }
}
.np-letter-heading {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.05;
  color: #fff;
  margin: 0 0 22px;
}
.np-letter-aside {
  font-size: 15px;
  color: rgba(255,255,255,0.7);
  line-height: 1.65;
  max-width: 320px;
}

.np-letter-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 22px;
}
.np-letter-item {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 22px;
  padding: 26px 28px;
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
  border: 1px solid rgba(255,255,255,0.10);
  transition: border-color 0.3s, background 0.3s, transform 0.3s;
}
.np-letter-item::before {
  content: '';
  position: absolute;
  left: 0; top: 50%;
  width: 3px; height: 0;
  background: linear-gradient(180deg, #4da3ff, transparent);
  border-radius: 9999px;
  transform: translateY(-50%);
  transition: height 0.4s cubic-bezier(0.22,1,0.36,1);
}
.np-letter-item:hover {
  border-color: rgba(77,163,255,0.30);
  background: linear-gradient(180deg, rgba(77,163,255,0.06), rgba(77,163,255,0.01));
  transform: scale(1.01);
}
.np-letter-item:hover::before {
  height: 70%;
}
.np-letter-num {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: #4da3ff;
  flex-shrink: 0;
  padding-top: 3px;
  letter-spacing: 0.05em;
}
.np-letter-text {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(17px, 1.8vw, 22px);
  font-weight: 500;
  color: rgba(255,255,255,0.92);
  line-height: 1.45;
  letter-spacing: -0.012em;
  margin: 0;
}

/* ════════════════════════════════════════════
   3. STATS
════════════════════════════════════════════ */
.np-stats {
  background: #15005f;
  position: relative;
  overflow: hidden;
  padding: 100px 0 110px;
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.np-stats-grid-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(77,163,255,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(77,163,255,0.05) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 70%, transparent 100%);
  -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 30%, #000 70%, transparent 100%);
}
.np-stats-header {
  text-align: center;
  max-width: 760px;
  margin: 0 auto 56px;
}
.np-stats-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.1;
  margin: 0;
}

.np-stats-grid {
  display: grid; grid-template-columns: 1fr; gap: 20px;
  max-width: 1024px; margin: 0 auto;
}
@media (min-width: 768px) { .np-stats-grid { grid-template-columns: repeat(3, 1fr); } }

.np-stat-card {
  padding: 36px 28px;
  border-radius: 22px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.10);
  text-align: left;
  transition: border-color 0.35s, transform 0.35s cubic-bezier(0.22,1,0.36,1);
}
.np-stat-card:hover {
  border-color: rgba(77,163,255,0.35);
  transform: scale(1.02);
}
.np-stat-num {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(48px, 7vw, 82px);
  font-weight: 700;
  letter-spacing: -0.035em;
  line-height: 1;
  background: linear-gradient(160deg, #fff 0%, #4da3ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 18px;
}
.np-stat-line {
  width: 38px; height: 2px;
  background: #4da3ff;
  border-radius: 9999px;
  margin-bottom: 14px;
}
.np-stat-label {
  font-size: 14px;
  color: rgba(255,255,255,0.78);
  line-height: 1.55;
  margin: 0;
}

/* ════════════════════════════════════════════
   4. REVEAL — Aquí entra Nawar Plus
════════════════════════════════════════════ */
.np-reveal {
  padding: 110px 0 64px;
  background: #fff;
}
@media (max-width: 767px) {
  .np-reveal { padding: 72px 0 32px; }
}
.np-reveal-content {
  text-align: center;
  max-width: 880px;
  margin: 0 auto;
}
.np-reveal-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(30px, 4.5vw, 56px);
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.1;
