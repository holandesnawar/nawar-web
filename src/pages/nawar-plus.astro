<script>
  // ── Parallax sutil en los glows del hero ──
  const heroGlow1 = document.querySelector('.np-hero-glow1') as HTMLElement | null
  const heroGlow2 = document.querySelector('.np-hero-glow2') as HTMLElement | null
  let rafId: number | null = null
  const onScroll = () => {
    if (rafId) return
    rafId = requestAnimationFrame(() => {
      const y = window.scrollY
      if (heroGlow1 && y < window.innerHeight * 1.5) {
        heroGlow1.style.transform = `translateY(${y * 0.18}px)`
      }
      if (heroGlow2 && y < window.innerHeight * 1.5) {
        heroGlow2.style.transform = `translateY(${y * -0.10}px)`
      }
      rafId = null
    })
  }
  window.addEventListener('scroll', onScroll, { passive: true })

  // ── Count-up de stats al entrar en viewport ──
  const statNums = document.querySelectorAll<HTMLElement>('.np-stat-num')
  const animateNumber = (el: HTMLElement) => {
    const raw = el.textContent || ''
    const match = raw.match(/(\d+)(.*)/)
    if (!match) return
    const target = parseInt(match[1], 10)
    const suffix = match[2]
    const prefix = raw.startsWith('€') ? '€' : ''
    const duration = 1400
    const start = performance.now()
    const step = (t: number) => {
      const p = Math.min((t - start) / duration, 1)
      const eased = 1 - Math.pow(1 - p, 3)
      const current = Math.round(target * eased)
      el.textContent = `${prefix}${current}${suffix}`
      if (p < 1) requestAnimationFrame(step)
    }
    requestAnimationFrame(step)
  }
  const statObs = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        animateNumber(e.target as HTMLElement)
        statObs.unobserve(e.target)
      }
    })
  }, { threshold: 0.4 })
  statNums.forEach((el) => statObs.observe(el))
</script>
