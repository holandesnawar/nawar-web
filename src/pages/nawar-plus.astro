}
.np-reveal-sub {
  font-size: 17px;
  color: #1D0084;
  opacity: 0.85;
  line-height: 1.7;
  max-width: 680px;
  margin: 0 auto;
}

/* ════════════════════════════════════════════
   5. VERTICALES
════════════════════════════════════════════ */
.np-vert-header {
  text-align: center;
  max-width: 700px;
  margin: 0 auto 48px;
}
.np-vert-section-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 600;
  letter-spacing: -0.02em;
  color: #1D0084;
  margin: 0 0 12px;
}
.np-vert-section-sub {
  font-size: 16px;
  color: #1D0084;
  opacity: 0.75;
  line-height: 1.6;
  margin: 0;
}
.np-vert-grid {
  display: grid; grid-template-columns: 1fr; gap: 20px;
}
@media (min-width: 768px) { .np-vert-grid { grid-template-columns: 1fr 1fr; } }

.np-vert-card {
  position: relative; overflow: hidden;
  background: #fff;
  border: 1px solid #DDE6F5;
  border-radius: 22px;
  padding: 32px 28px;
  box-shadow: 0 2px 16px rgba(29,0,132,0.05);
  transition: transform 0.35s cubic-bezier(0.22,1,0.36,1), border-color 0.35s;
  display: flex; flex-direction: column; height: 100%;
}
.np-vert-card::before {
  content: '';
  position: absolute;
  top: -1px; left: -1px; right: -1px;
  height: 3px;
  background: linear-gradient(90deg, transparent, #4da3ff, transparent);
  opacity: 0;
  transition: opacity 0.4s;
}
.np-vert-card:hover {
  transform: scale(1.015);
  border-color: rgba(77,163,255,0.40);
}
.np-vert-card:hover::before { opacity: 1; }

.np-vert-icon-wrap {
  display: inline-flex;
  align-items: center; justify-content: center;
  width: 56px; height: 56px;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(77,163,255,0.18) 0%, rgba(77,163,255,0.06) 100%);
  border: 1px solid rgba(77,163,255,0.20);
