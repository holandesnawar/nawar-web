  margin: 0 0 22px;
}
.np-vert-split {
  border-top: 1px solid #DDE6F5;
  padding-top: 18px;
  display: flex; flex-direction: column; gap: 10px;
}
.np-vert-split-row { display: flex; align-items: flex-start; gap: 12px; }
.np-vert-split-label {
  flex-shrink: 0;
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  padding: 4px 10px; border-radius: 9999px;
  min-width: 56px; text-align: center;
}
.np-vert-split-free {
  background: #F0F5FF;
  color: #5A6480;
  border: 1px solid #DDE6F5;
}
.np-vert-split-plus {
  background: rgba(77,163,255,0.14);
  color: #025dc7;
  border: 1px solid rgba(77,163,255,0.30);
}
.np-vert-split-value {
  font-size: 13px; color: #1D0084; line-height: 1.45; font-weight: 500;
  padding-top: 3px;
}

/* ════════════════════════════════════════════
   6. COMPARATIVA
════════════════════════════════════════════ */
.np-comp {
  background: #1D0084;
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}
.np-comp-glow {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 900px; height: 600px; border-radius: 50%;
  background: radial-gradient(ellipse at center, rgba(77,163,255,0.20) 0%, transparent 65%);
  pointer-events: none;
}
.np-comp-header {
  text-align: center; max-width: 760px; margin: 0 auto 56px;
}
.np-comp-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(30px, 4.5vw, 56px);
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.1;
  margin: 0 0 18px;
}
.np-comp-sub {
  font-size: 17px; color: rgba(255,255,255,0.82); line-height: 1.65;
  margin: 0;
}

.np-comp-grid {
  display: grid; grid-template-columns: 1fr; gap: 24px;
  max-width: 980px; margin: 0 auto;
  align-items: stretch;
}
@media (min-width: 900px) { .np-comp-grid { grid-template-columns: 1fr 1fr; } }

.np-comp-card {
  position: relative; overflow: hidden;
  border-radius: 24px;
  padding: 36px 32px;
  display: flex; flex-direction: column;
  height: 100%;
  transition: transform 0.35s cubic-bezier(0.22,1,0.36,1);
  will-change: transform;
}
.np-comp-card:hover { transform: scale(1.015); }
.np-comp-free {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.12);
}
.np-comp-plus {
  background: linear-gradient(160deg, rgba(11,109,240,0.20) 0%, rgba(77,163,255,0.08) 100%);
  border: 1.5px solid rgba(77,163,255,0.50);
}
.np-comp-card-glow {
  position: absolute; top: -120px; right: -120px;
  width: 380px; height: 380px; border-radius: 50%;
  background: radial-gradient(circle, rgba(77,163,255,0.32) 0%, transparent 65%);
  pointer-events: none;
}
.np-comp-ribbon {
  position: absolute; top: 18px; right: 22px;
  background: #4da3ff; color: #1D0084;
  font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
  padding: 5px 12px; border-radius: 9999px;
  text-transform: uppercase;
  box-shadow: 0 4px 18px rgba(77,163,255,0.40);
  z-index: 2;
}

.np-comp-card-top { margin-bottom: 24px; position: relative; z-index: 1; }
.np-comp-tag {
  display: inline-block;
  font-size: 11px; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 5px 12px; border-radius: 9999px;
  margin-bottom: 16px;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.10);
  border: 1px solid rgba(255,255,255,0.18);
}
.np-comp-tag-plus {
  color: #4da3ff;
  background: rgba(77,163,255,0.14);
  border-color: rgba(77,163,255,0.34);
}
.np-comp-price { display: flex; align-items: baseline; gap: 4px; margin-bottom: 8px; }
.np-comp-amount {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: 56px; font-weight: 700; line-height: 1; letter-spacing: -0.025em;
  color: rgba(255,255,255,0.85);
}
.np-comp-period { font-size: 16px; color: rgba(255,255,255,0.5); font-weight: 500; }
.np-comp-desc { font-size: 14px; color: rgba(255,255,255,0.7); line-height: 1.55; margin: 0; }

/* ── Lista comp — checks MINIMALISTAS (sin bolita) ── */
.np-comp-list {
  list-style: none; padding: 0; margin: 0 0 28px;
  display: flex; flex-direction: column; gap: 14px;
  flex: 1;
  position: relative; z-index: 1;
}
.np-comp-list li {
  display: flex; align-items: flex-start; gap: 14px;
  font-size: 14.5px; color: rgba(255,255,255,0.88); line-height: 1.55;
  padding-bottom: 14px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.np-comp-list li > span:last-child { flex: 1; min-width: 0; }
.np-comp-list li:last-child { border-bottom: none; padding-bottom: 0; }
.np-tick {
  flex-shrink: 0;
  width: 18px; height: 18px;
  margin-top: 3px;
  position: relative;
}
.np-tick::after {
  content: '';
  position: absolute;
  left: 2px; top: 4px;
  width: 10px; height: 6px;
  border-left: 2px solid rgba(255,255,255,0.55);
  border-bottom: 2px solid rgba(255,255,255,0.55);
  transform: rotate(-45deg);
}
.np-tick-plus::after {
  border-color: #4da3ff;
  width: 11px; height: 6px;
}
.np-tick-off { opacity: 0.55; }
.np-tick-off::after {
  content: '';
  position: absolute;
  left: 4px; top: 8px;
  width: 10px; height: 0;
  border-top: 2px solid rgba(255,255,255,0.45);
  border-left: none;
  border-bottom: none;
  transform: none;
}
.np-comp-locked { color: rgba(255,255,255,0.5) !important; }

.np-comp-cta {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  padding: 16px 24px; border-radius: 12px;
  font-size: 15px; font-weight: 700;
  text-decoration: none;
  width: 100%;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  position: relative; z-index: 1;
}
.np-comp-cta-free {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.18);
  color: #fff;
}
.np-comp-cta-free:hover {
  background: rgba(255,255,255,0.14);
  transform: translateY(-1px);
  border-color: rgba(255,255,255,0.30);
}
.np-comp-cta-plus {
  background: #4da3ff;
  color: #1D0084;
  box-shadow: 0 6px 24px rgba(77,163,255,0.35);
}
.np-comp-cta-plus:hover {
  background: #5eb4ff;
  transform: translateY(-1px);
  box-shadow: 0 10px 32px rgba(77,163,255,0.50);
}
.np-comp-cancel {
  text-align: center;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  margin-top: 14px;
  position: relative; z-index: 1;
}

/* ════════════════════════════════════════════
   7. PRECIO
════════════════════════════════════════════ */
.np-price {
