---
import { sanityClient } from 'sanity:client'
import Layout from '../layouts/Layout.astro'
import { LANDING_QUERY } from '../sanity/queries'

import NavbarLanding from '../components/NavbarLanding'
import HeroSection from '../components/HeroSection.astro'
import StatsSection from '../components/StatsSection.astro'
import MarqueeSection from '../components/MarqueeSection.astro'
import PainPointsSection from '../components/PainPointsSection.astro'
import FeaturesSection from '../components/FeaturesSection.astro'
import StepsSection from '../components/StepsSection'
import StickyComparisonSection from '../components/StickyComparisonSection'
import TestimonialsSection from '../components/TestimonialsSection.astro'
import AboutSection from '../components/AboutSection.astro'
import CallToActionSection from '../components/CallToActionSection.astro'
import DoubtSection from '../components/DoubtSection.astro'
import FooterLanding from '../components/FooterLanding'

export const prerender = false

const page = await sanityClient.fetch(LANDING_QUERY)

// Fallbacks for when Sanity document doesn't exist yet
const hero         = page?.hero         ?? {}
const stats        = page?.stats        ?? []
const marqueeItems = page?.marqueeItems ?? []
const painPoints   = page?.painPoints   ?? []
const features     = page?.features     ?? []
const steps        = page?.steps        ?? []
const comparison   = page?.comparison   ?? []
const testimonials = page?.testimonials ?? []
const doubts       = page?.doubts       ?? []
const about        = page?.about        ?? {}
---

<Layout
  title="Nawar — Aprende neerlandés online"
  description="Academia de neerlandés para hispanohablantes. Clases en vivo, método desde el español y comunidad activa."
>
  <NavbarLanding client:load />

  <HeroSection hero={hero} />
  <StatsSection stats={stats} />
  <MarqueeSection items={marqueeItems} />
  <PainPointsSection painPoints={painPoints} />
  <FeaturesSection features={features} />
  <StepsSection steps={steps} client:load />
  <StickyComparisonSection items={comparison} client:load />
  <TestimonialsSection testimonials={testimonials} />
  <AboutSection about={about} />
  <CallToActionSection />
  <DoubtSection doubts={doubts} />
  <FooterLanding client:load />
</Layout>
