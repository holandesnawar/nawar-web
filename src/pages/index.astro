---
import Layout from '../layouts/Layout.astro'
import landing from '../data/landing.json'

import NavbarLanding from '../components/NavbarLanding'
import HeroNuevo from '../components/HeroNuevo.astro'
import GuidePopup from '../components/GuidePopup.astro'
// PainPointsSection eliminada temporalmente — para restaurar: import PainPointsSection from '../components/PainPointsSection.astro'
import StickyComparisonSection from '../components/StickyComparisonSection'
import TestimonialsSection from '../components/TestimonialsSection.astro'
import PorQueNawar from '../components/PorQueNawar.astro'
// BenefitsSection oculta temporalmente hasta que la formación esté lista — para restaurar: import BenefitsSection from '../components/BenefitsSection.astro'
import ProcesoSection from '../components/ProcesoSection.astro'
import ParaQuienSection from '../components/ParaQuienSection.astro'
import ValorNuevo from '../components/ValorNuevo.astro'
import BlogNuevo from '../components/BlogNuevo.astro'
import FAQNuevo from '../components/FAQNuevo.astro'
import FooterNuevo from '../components/FooterNuevo.astro'
import '../styles/nawar-sections.css'

export const prerender = true

const painPoints   = landing.painPoints   ?? []
const comparison   = landing.comparison   ?? []
const testimonials = landing.testimonials ?? []
const porQueNawar  = landing.porQueNawar  ?? null
const benefits     = landing.benefits     ?? null
const proceso      = landing.proceso      ?? null
const valor        = landing.valor        ?? null
const paraQuien    = landing.paraQuien    ?? null
const faq          = landing.faq          ?? null
---

<Layout
  title="Nawar | Aprende Holandés desde el Español"
  description="Domina el neerlandés con Nawar, la academia online exclusiva para hispanohablantes. Método probado desde el español, clases en vivo y comunidad. ¡Empieza hoy!"
>
  <NavbarLanding client:load />
  <GuidePopup />

  <HeroNuevo />
  <PorQueNawar data={porQueNawar} />
  {/* <BenefitsSection data={benefits} /> — oculta hasta que la formación esté lista */}
  <ProcesoSection data={proceso} />
  <ValorNuevo data={valor} />
  <StickyComparisonSection items={comparison} client:load />
  <ParaQuienSection data={paraQuien} />
  {/* <PainPointsSection painPoints={painPoints} /> — eliminada temporalmente */}
  <BlogNuevo />
  <FAQNuevo data={faq} />
  <TestimonialsSection testimonials={testimonials} />
  <FooterNuevo />
</Layout>
