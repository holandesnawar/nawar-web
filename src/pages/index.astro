---
import { sanityClient } from 'sanity:client'
import Layout from '../layouts/Layout.astro'
import { LANDING_QUERY } from '../sanity/queries'

import NavbarLanding from '../components/NavbarLanding'
import HeroNuevo from '../components/HeroNuevo.astro'
import PainPointsSection from '../components/PainPointsSection.astro'
import StickyComparisonSection from '../components/StickyComparisonSection'
import TestimonialsSection from '../components/TestimonialsSection.astro'
import PorQueNawar from '../components/PorQueNawar.astro'
import BenefitsSection from '../components/BenefitsSection.astro'
import ProcesoSection from '../components/ProcesoSection.astro'
import ParaQuienSection from '../components/ParaQuienSection.astro'
import ValorNuevo from '../components/ValorNuevo.astro'
import BlogNuevo from '../components/BlogNuevo.astro'
import FAQNuevo from '../components/FAQNuevo.astro'
import FooterNuevo from '../components/FooterNuevo.astro'
import '../styles/nawar-sections.css'

export const prerender = false

const page = await sanityClient.fetch(LANDING_QUERY)

const painPoints   = page?.painPoints   ?? []
const comparison   = page?.comparison   ?? []
const testimonials = page?.testimonials ?? []
const porQueNawar  = page?.porQueNawar  ?? null
const benefits     = page?.benefits     ?? null
const proceso      = page?.proceso      ?? null
const valor        = page?.valor        ?? null
const paraQuien    = page?.paraQuien    ?? null
const faq          = page?.faq          ?? null
---

<Layout
  title="Nawar — Aprende neerlandés online"
  description="Academia de neerlandés para hispanohablantes. Clases en vivo, método desde el español y comunidad activa."
>
  <NavbarLanding client:load />

  <HeroNuevo />
  <PorQueNawar data={porQueNawar} />
  <BenefitsSection data={benefits} />
  <ProcesoSection data={proceso} />
  <ValorNuevo data={valor} />
  <StickyComparisonSection items={comparison} client:load />
  <ParaQuienSection data={paraQuien} />
  <PainPointsSection painPoints={painPoints} />
  <BlogNuevo />
  <FAQNuevo data={faq} />
  <TestimonialsSection testimonials={testimonials} />
  <FooterNuevo />
</Layout>
