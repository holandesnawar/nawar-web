---
interface Props { data?: any }
const { data } = Astro.props
const badge = data?.badge ?? '¿Qué incluye?'
const title = data?.title ?? 'Todo lo que necesitas para aprender de verdad'
const subtitle = data?.subtitle ?? 'Nada de suerte. Un sistema completo diseñado para que avances desde el primer día.'
---
<section class="benefits-section" data-navbar="light">
  <div class="inner">

    <div class="benefits-header sr">
      <span class="badge-light">
        <svg class="check-icon" fill="none" viewBox="0 0 12 12">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {badge}
      </span>
      <h2 class="benefits-title" set:html={title.replace(/\n/g, '<br>')} />
      <p class="benefits-sub">{subtitle}</p>
    </div>

    <div class="benefits-grid">

      <!-- Card 1: Formación estructurada -->
      <div class="benefit-card sr">
        <div class="benefit-visual">
          <div class="benefit-visual-glow" style="top:-80px;left:-80px;width:300px;height:300px;background:radial-gradient(circle,rgba(29,0,132,0.50) 0%,transparent 65%);"></div>
          <div class="benefit-visual-glow" style="bottom:-60px;right:-40px;width:220px;height:220px;background:radial-gradient(circle,rgba(11,109,240,0.35) 0%,transparent 65%);"></div>
          <div class="mock-module">
            <div class="mock-module-row">
              <span class="mock-dot mock-dot--done"></span>
              <span class="mock-line"></span>
              <span class="mock-pill mock-pill--done">Completado</span>
            </div>
            <div class="mock-module-row">
              <span class="mock-dot mock-dot--done"></span>
              <span class="mock-line mock-line--short"></span>
              <span class="mock-pill mock-pill--done">Completado</span>
            </div>
            <div class="mock-module-row">
              <span class="mock-dot mock-dot--prog"></span>
              <span class="mock-line"></span>
              <span class="mock-pill mock-pill--live">En curso</span>
            </div>
            <div class="mock-module-row">
              <span class="mock-dot mock-dot--todo"></span>
              <span class="mock-line mock-line--short"></span>
            </div>
          </div>
        </div>
        <div class="benefit-body">
          <span class="benefit-badge">
            <svg width="10" height="10" fill="none" viewBox="0 0 12 12"><path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Formación
          </span>
          <h3 class="benefit-card-title">Aprende por niveles, paso a paso</h3>
          <p class="benefit-card-desc">10+ horas de contenido estructurado por módulos. Desde cero hasta conversación fluida, con vídeos cortos y ejercicios prácticos.</p>
        </div>
      </div>

      <!-- Card 2: Comunidad -->
      <div class="benefit-card sr d1">
        <div class="benefit-visual">
          <div class="benefit-visual-glow" style="top:-60px;right:-60px;width:260px;height:260px;background:radial-gradient(circle,rgba(77,163,255,0.30) 0%,transparent 65%);"></div>
          <div class="mock-chat">
            <div class="mock-chat-header">
              <span class="mock-chat-name">🇳🇱 Comunidad Nawar</span>
              <span class="mock-chat-count">+600 miembros</span>
            </div>
            <div>
              <p class="mock-bubble-meta">Carlos · hace 5 min</p>
              <div class="mock-bubble mock-bubble--in">¿Habéis practicado "ik woon in..." para presentaros? Funciona muy bien 🏠</div>
            </div>
            <div>
              <p class="mock-bubble-meta">Ana · hace 3 min</p>
              <div class="mock-bubble mock-bubble--in">Sí! Y ya no me da vergüenza hablar con mis vecinos 😄</div>
            </div>
            <div style="text-align:right;">
              <p class="mock-bubble-meta" style="text-align:right;">Tú · ahora</p>
              <div class="mock-bubble mock-bubble--out">¡Qué bien! Yo llevo 2 semanas y ya entiendo el super 🎉</div>
            </div>
          </div>
        </div>
        <div class="benefit-body">
          <span class="benefit-badge">
            <svg width="10" height="10" fill="none" viewBox="0 0 12 12"><path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Comunidad
          </span>
          <h3 class="benefit-card-title">No aprendes solo. Avanzas con otros</h3>
          <p class="benefit-card-desc">Acceso a la comunidad privada de hispanohablantes. Practica, resuelve dudas y mantén la motivación rodeado de personas con tu mismo objetivo.</p>
        </div>
      </div>

      <!-- Card 3: Clases en vivo -->
      <div class="benefit-card sr d2">
        <div class="benefit-visual">
          <div class="benefit-visual-glow" style="top:-60px;left:-40px;width:240px;height:240px;background:radial-gradient(circle,rgba(16,185,129,0.20) 0%,transparent 65%);"></div>
          <div class="mock-video">
            <div class="mock-video-header">
              <span class="mock-video-title">Clase semanal · Módulo 3</span>
              <span class="mock-video-live">
                <span class="mock-video-live-dot"></span>
                EN DIRECTO
              </span>
            </div>
            <div class="mock-video-body">
              <div class="mock-video-play">
                <svg width="14" height="14" fill="white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
            </div>
            <div class="mock-video-avatars">
              <div class="mock-avatar-sm">🇪🇸</div>
              <div class="mock-avatar-sm">🇲🇽</div>
              <div class="mock-avatar-sm">🇨🇴</div>
              <div class="mock-avatar-sm">🇦🇷</div>
              <span class="mock-avatar-count">+24 asistentes</span>
            </div>
          </div>
        </div>
        <div class="benefit-body">
          <span class="benefit-badge">
            <svg width="10" height="10" fill="none" viewBox="0 0 12 12"><path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Clases en vivo
          </span>
          <h3 class="benefit-card-title">Sesiones en vivo incluidas en la primera edición</h3>
          <p class="benefit-card-desc">Clases en directo previstas para el lanzamiento: practica conversación real y resuelve dudas con profesores que hablan español y entienden tu punto de partida.</p>
        </div>
      </div>

      <!-- Card 4: Material exclusivo -->
      <div class="benefit-card sr d3">
        <div class="benefit-visual">
          <div class="benefit-visual-glow" style="bottom:-60px;left:-40px;width:260px;height:260px;background:radial-gradient(circle,rgba(29,0,132,0.45) 0%,transparent 65%);"></div>
          <div class="benefit-visual-glow" style="top:-40px;right:-40px;width:180px;height:180px;background:radial-gradient(circle,rgba(77,163,255,0.25) 0%,transparent 65%);"></div>
          <div class="mock-vocab">
            <div class="mock-vocab-card">
              <div class="mock-vocab-nl">goedemorgen</div>
              <div class="mock-vocab-es">buenos días</div>
              <div class="mock-vocab-tag">saludo · básico</div>
            </div>
            <div class="mock-vocab-card">
              <div class="mock-vocab-nl">ik heet...</div>
              <div class="mock-vocab-es">me llamo...</div>
              <div class="mock-vocab-tag">presentación</div>
            </div>
            <div class="mock-vocab-card">
              <div class="mock-vocab-nl">hoe gaat het?</div>
              <div class="mock-vocab-es">¿cómo estás?</div>
              <div class="mock-vocab-tag">conversación</div>
            </div>
            <div class="mock-vocab-card">
              <div class="mock-vocab-nl">dank je wel</div>
              <div class="mock-vocab-es">muchas gracias</div>
              <div class="mock-vocab-tag">cortesía</div>
            </div>
          </div>
        </div>
        <div class="benefit-body">
          <span class="benefit-badge">
            <svg width="10" height="10" fill="none" viewBox="0 0 12 12"><path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Material exclusivo
          </span>
          <h3 class="benefit-card-title">Fichas, vocabulario y recursos propios</h3>
          <p class="benefit-card-desc">Material creado desde el español. Fichas de vocabulario, guías de pronunciación y ejercicios que no encontrarás en ningún otro sitio.</p>
        </div>
      </div>

    </div>
  </div>
</section>
