---
interface Props { data?: any }
const { data } = Astro.props
const badge = data?.badge ?? 'Así de sencillo'
const title = data?.title ?? 'Dos clics. Listo.'
const subtitle = data?.subtitle ?? 'Sin trámites, sin esperas eternas. En minutos tienes acceso a todo y empiezas a avanzar.'
const guaranteeText = data?.guaranteeText ?? 'Garantía de devolución 15 días'
const ctaText = data?.ctaText ?? 'Unirte'
---
<div class="proceso-wrapper">
<div class="proceso-outer" data-navbar="dark">
  <section class="proceso-section">
    <div class="proceso-glow-tl" aria-hidden="true"></div>
    <div class="proceso-glow-br" aria-hidden="true"></div>

    <!-- Globo decorativo SVG -->
    <div class="proceso-globe" aria-hidden="true">
      <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="250" cy="250" r="220" stroke="rgba(77,163,255,0.30)" stroke-width="1"/>
        <circle cx="250" cy="250" r="160" stroke="rgba(77,163,255,0.20)" stroke-width="1"/>
        <circle cx="250" cy="250" r="100" stroke="rgba(77,163,255,0.18)" stroke-width="1"/>
        <ellipse cx="250" cy="250" rx="220" ry="60"  stroke="rgba(77,163,255,0.18)" stroke-width="1"/>
        <ellipse cx="250" cy="250" rx="220" ry="110" stroke="rgba(77,163,255,0.15)" stroke-width="1"/>
        <ellipse cx="250" cy="250" rx="220" ry="170" stroke="rgba(77,163,255,0.13)" stroke-width="1"/>
        <ellipse cx="250" cy="250" rx="60"  ry="220" stroke="rgba(77,163,255,0.18)" stroke-width="1"/>
        <ellipse cx="250" cy="250" rx="110" ry="220" stroke="rgba(77,163,255,0.15)" stroke-width="1"/>
        <ellipse cx="250" cy="250" rx="170" ry="220" stroke="rgba(77,163,255,0.13)" stroke-width="1"/>
        <line x1="250" y1="30"  x2="250" y2="470" stroke="rgba(77,163,255,0.22)" stroke-width="1"/>
        <line x1="30"  y1="250" x2="470" y2="250" stroke="rgba(77,163,255,0.22)" stroke-width="1"/>
        <!-- Arco brillante accent -->
        <path d="M250 30 Q340 130 370 250 Q340 370 250 470" stroke="#4da3ff" stroke-width="2" fill="none" opacity="0.55"/>
        <path d="M250 30 Q160 130 130 250 Q160 370 250 470" stroke="#4da3ff" stroke-width="1.2" fill="none" opacity="0.28"/>
        <!-- Puntos de intersección -->
        <circle cx="250" cy="30"  r="4" fill="#4da3ff" opacity="0.6"/>
        <circle cx="250" cy="470" r="4" fill="#4da3ff" opacity="0.6"/>
        <circle cx="30"  cy="250" r="4" fill="#4da3ff" opacity="0.4"/>
        <circle cx="470" cy="250" r="4" fill="#4da3ff" opacity="0.4"/>
        <circle cx="370" cy="250" r="5" fill="#4da3ff" opacity="0.7"/>
      </svg>
    </div>

    <div class="inner" style="position:relative;z-index:1;">

      <div class="proceso-header">
        <span class="badge-dark">
          <svg class="check-icon" fill="none" viewBox="0 0 12 12">
            <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {badge}
        </span>
        <h2 class="proceso-title text-gradient-white">{title}</h2>
        <p class="proceso-sub">{subtitle}</p>
      </div>

      <div class="proceso-steps">

        <!-- Paso 01 -->
        <div class="proceso-card sr">
          <div class="proceso-card-glow" aria-hidden="true"></div>
          <div class="proceso-num">01</div>
          <h3 class="proceso-card-title">Solicita tu plaza</h3>
          <ul class="proceso-perks">
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Rellena el formulario en menos de 2 minutos
            </li>
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Sin tarjeta de crédito para empezar
            </li>
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Plazas limitadas por cohorte
            </li>
          </ul>
          <div class="proceso-mockup">
            <div class="proceso-mockup-inner">
              <div class="pm-row">
                <span class="pm-label">Nombre</span>
                <span class="pm-value">María García</span>
              </div>
              <div class="pm-row">
                <span class="pm-label">Nivel actual</span>
                <span class="pm-badge">Principiante</span>
              </div>
              <div class="pm-row">
                <span class="pm-label">Objetivo</span>
                <span class="pm-value">Vivir en Países Bajos</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Paso 02 -->
        <div class="proceso-card sr d1">
          <div class="proceso-card-glow" aria-hidden="true"></div>
          <div class="proceso-num">02</div>
          <h3 class="proceso-card-title">Recibe acceso inmediato</h3>
          <ul class="proceso-perks">
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Toda la formación disponible al instante
            </li>
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Acceso a la comunidad privada desde el día 1
            </li>
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Confirmación por correo en segundos
            </li>
          </ul>
          <div class="proceso-mockup">
            <div class="proceso-mockup-inner">
              <div class="pm-row">
                <span class="pm-label">Estado</span>
                <span class="pm-badge">✓ Activo</span>
              </div>
              <div class="pm-row">
                <span class="pm-label">Acceso</span>
                <span class="pm-value">Todos los módulos</span>
              </div>
              <div class="pm-row">
                <span class="pm-label">Comunidad</span>
                <span class="pm-value">Invitación enviada</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Paso 03 -->
        <div class="proceso-card sr d2">
          <div class="proceso-card-glow" aria-hidden="true"></div>
          <div class="proceso-num">03</div>
          <h3 class="proceso-card-title">Empieza a hablar neerlandés</h3>
          <ul class="proceso-perks">
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Sigue el método paso a paso desde el español
            </li>
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Resultados visibles en las primeras semanas
            </li>
            <li>
              <span class="proceso-check">
                <svg width="10" height="10" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              Garantía 15 días o te devolvemos el dinero
            </li>
          </ul>
          <div class="proceso-mockup">
            <div class="proceso-mockup-inner">
              <div class="pm-row">
                <span class="pm-label">Progreso</span>
                <span class="pm-value">Módulo 2 · 40%</span>
              </div>
              <div class="pm-row">
                <span class="pm-label">Próxima clase</span>
                <span class="pm-badge">Jueves 19:00</span>
              </div>
              <div class="pm-row">
                <span class="pm-label">Racha</span>
                <span class="pm-value">🔥 7 días seguidos</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- CTA final -->
      <div class="proceso-cta-wrap sr">
        <a href="#apuntate" class="btn-proceso-cta">
          {ctaText}
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <p class="proceso-garantia" style="color: rgba(255, 255, 255, 0.85);">
          <span style="flex-shrink:0;width:22px;height:22px;border-radius:50%;background:rgba(77,163,255,0.18);border:1px solid rgba(77,163,255,0.40);display:inline-flex;align-items:center;justify-content:center;">
            <svg width="11" height="11" fill="none" stroke="#4da3ff" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </span>
          {guaranteeText}
        </p>
      </div>

    </div>
  </section>
</div>
</div>
