---
interface PainPoint { icon: string; title: string; description: string }
interface Props { painPoints: PainPoint[] }
const { painPoints } = Astro.props

const delayClass = (i: number) => ['','d1','d2','d3'][i % 4]
---

<section data-navbar="dark" class="relative bg-[#1D0084] overflow-hidden py-16 md:py-32">
  <div aria-hidden class="absolute inset-0 pointer-events-none">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[700px]"
      style="background: radial-gradient(ellipse at center, rgba(11,109,240,0.35) 0%, transparent 65%)"
    />
  </div>
  <div aria-hidden class="absolute inset-0 dots-dark pointer-events-none" />

  <div class="relative max-w-6xl mx-auto px-6">

    <div class="sr text-center max-w-2xl mx-auto mb-20 space-y-5">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#025dc7] text-[#e0f2ff] eyebrow">
        <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        El problema real
      </span>
      <h2 class="title">
        <span class="text-gradient-white">Por qué el neerlandés</span><br class="hidden sm:block" />
        <span style="color: #4da3ff; -webkit-text-fill-color: #4da3ff;">se siente imposible</span>
      </h2>
      <p class="text-[18px] text-white/50 leading-relaxed">
        No es que sea difícil. Es que nadie lo enseña desde el español.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {painPoints.map((p, i) => (
        <div class={`sr ${delayClass(i)} glass rounded-2xl p-8 flex flex-col gap-5`}>
          <div class="w-12 h-12 rounded-2xl bg-white/8 border border-white/12 flex items-center justify-center text-2xl">
            {p.icon}
          </div>
          <div class="space-y-2">
            <h3 class="text-[16px] font-bold text-white">{p.title}</h3>
            <p class="text-[14px] text-white/55 leading-relaxed">{p.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
