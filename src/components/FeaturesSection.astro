---
interface Feature { icon: string; title: string; description: string }
interface Props { features: Feature[] }
const { features } = Astro.props

const delayClass = (i: number) => ['','d1','d2','d3'][i % 4]
---

<section data-navbar="light" id="metodo" class="relative bg-white overflow-hidden py-16 md:py-32">
  <div aria-hidden class="absolute inset-0 dots-light pointer-events-none" />
  <div aria-hidden class="absolute inset-0 pointer-events-none">
    <div
      class="absolute -top-20 left-1/2 -translate-x-1/2 w-[800px] h-[500px]"
      style="background: radial-gradient(ellipse at center, rgba(2,93,199,0.06) 0%, transparent 65%)"
    />
  </div>

  <div class="relative max-w-6xl mx-auto px-6">

    <div class="sr text-center max-w-2xl mx-auto mb-20 space-y-5">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#dde8f8] text-[#1D0084] eyebrow">
        <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        El método Nawar
      </span>
      <h2 class="title text-[#1D0084]">
        Por qué aprenderás más rápido{' '}
        <span class="text-[#025dc7]">aquí</span>
      </h2>
      <p class="text-[18px] text-[#4A5568] leading-relaxed max-w-lg mx-auto">
        No es un curso de idiomas genérico. Es un método construido desde cero para hispanohablantes, con o sin experiencia previa.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <div class={`sr ${delayClass(i)} group card-soft rounded-2xl p-8 flex flex-col gap-5 h-full`}>
          <div class="w-12 h-12 rounded-2xl bg-[#1D0084]/10 border border-[#1D0084]/14 flex items-center justify-center text-2xl group-hover:scale-110 group-hover:bg-[#1D0084]/16 transition-all duration-300">
            {f.icon}
          </div>
          <div class="space-y-2 flex-1">
            <h3 class="text-[16px] font-bold text-[#1D0084]">{f.title}</h3>
            <p class="text-[14px] text-[#4A5568] leading-relaxed">{f.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
