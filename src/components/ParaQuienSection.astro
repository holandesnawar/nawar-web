---
interface Props { data?: any }
const { data } = Astro.props
const badge = data?.badge ?? '¿Para quién está diseñado?'
const subtitle = data?.subtitle ?? 'Tanto si llegas a Países Bajos como si ya vives allí,\nel neerlandés te abre puertas que el inglés no puede.'
const defaultPoints = [
  { icon: '🏠', title: 'Residentes', description: 'Aprender el idioma abre la puerta a la vida cotidiana y un verdadero sentido de pertenencia en los Países Bajos.' },
  { icon: '✈️', title: 'Nueva Vida', description: 'Aprender antes de llegar te da la confianza para empezar tu nueva etapa con seguridad desde el primer día.' },
  { icon: '💼', title: 'Profesionales', description: 'Mejora tu comunicación con colegas, gana reconocimiento laboral y accede a mejores oportunidades.' },
  { icon: '🎓', title: 'Formación', description: 'Domina el idioma para acceder a universidades neerlandesas, programas y becas de formación.' },
]
const points = data?.points?.length ? data.points : defaultPoints
---

<div class="pq-wrapper">
  <div class="pq-outer" data-navbar="dark">
    <section class="pq-section">
      <div class="pq-bg-glow" aria-hidden="true"></div>
      <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;opacity:0.5;"></div>
      <div class="inner" style="position:relative;z-index:1;">

        <div class="pq-header sr">
          <span class="badge-dark">
            <svg class="check-icon" fill="none" viewBox="0 0 12 12">
              <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {badge}
          </span>
          <h2 class="pq-title">
            <span class="text-gradient-white">Un método pensado</span><br>
            <span style="color: #4da3ff; -webkit-text-fill-color: #4da3ff;">para cada etapa</span>
          </h2>
          <p class="pq-sub pq-sub-desktop">
            Tanto si llegas a Países Bajos como si ya vives allí,<br>
            el neerlandés te abre puertas que el inglés no puede.
          </p>
          <p class="pq-sub pq-sub-mobile">
            El neerlandés abre puertas que el inglés no puede.
          </p>
        </div>

        <!-- Desktop: photo left + 2x2 grid right | Mobile: photo + swipe cards -->
        <div class="pq-layout">

          <!-- Photo -->
          <div class="pq-photo-col">
            <div class="pq-photo-wrap">
              <img
                src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=600&h=900&fit=crop&q=80"
                alt="Estudiantes aprendiendo neerlandés"
                class="pq-photo"
              />
            </div>
          </div>

          <!-- Points -->
          <div class="pq-points-col">
            <div class="pq-points-scroll">
              {points.map((pt: any, i: number) => (
                <div class={`pq-point sr${i > 0 ? ` d${i}` : ''}`}>
                  <div class="pq-point-card">
                    <div class="pq-point-icon">{pt.icon}</div>
                    <div class="pq-point-text">
                      <h3 class="pq-point-title">{pt.title}</h3>
                      <p class="pq-point-desc">{pt.description}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Mobile swipe hint -->
            <div class="pq-swipe-hint" aria-hidden="true">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
              Desliza para ver más
            </div>
          </div>

        </div>
      </div>
    </section>
  </div>
</div>

<style>
/* ── Outer wrapper (like proceso) ── */
.pq-wrapper {
  background: #F0F4FF;
  padding: 0 48px 80px;
}
.pq-outer {
  overflow: hidden;
  position: relative;
  border-radius: 32px;
  max-width: 1280px;
  margin-left: auto;
  margin-right: auto;
}

/* ── Section ── */
.pq-section {
  background: #1D0084;
  position: relative;
  overflow: hidden;
  padding: 80px 0;
}
.pq-bg-glow {
  position: absolute; top: -20%; left: 50%; transform: translateX(-50%);
  width: 900px; height: 600px;
  background: radial-gradient(ellipse at center, rgba(11,109,240,0.30) 0%, transparent 65%);
  pointer-events: none;
}

/* ── Header ── */
.pq-header { text-align: center; max-width: 820px; margin: 0 auto 64px; }
.pq-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: clamp(28px, 4vw, 52px);
  font-weight: 600; letter-spacing: -0.022em; line-height: 1.1;
  margin-bottom: 18px;
}
.pq-sub {
  font-size: clamp(14px, 1.4vw, 17px);
  color: rgba(255,255,255,0.62);
  line-height: 1.65;
  max-width: 520px;
  margin: 0 auto;
}

/* ── Desktop layout: photo left + 2×2 grid right ── */
/* fr units descuentan el gap automáticamente, evitando overflow */
.pq-layout {
  display: grid;
  grid-template-columns: 2fr 3fr;
  gap: 48px;
  align-items: start;
}

/* Photo column */
.pq-photo-col { display: flex; align-items: flex-start; }
.pq-photo-wrap {
  border-radius: 20px; overflow: hidden;
  width: 100%;
  position: sticky; top: 92px;
  height: 380px;
}
.pq-photo {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* Points column: 2×2 grid */
.pq-points-col { display: flex; flex-direction: column; }
.pq-points-scroll {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  flex: 1;
}

/* Each item: clean, no borders, less padding */
.pq-point {
  padding: 0;
  min-width: 0; /* ← permite que el texto haga wrap dentro del grid */
}
.pq-point-card {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 20px 20px 20px 0;
  transition: none;
}
.pq-points-scroll .pq-point:nth-child(even) .pq-point-card {
  padding-left: 24px;
  padding-right: 0;
  border-left: none;
}
.pq-points-scroll .pq-point:nth-last-child(-n+2) .pq-point-card {
  border-bottom: none;
  padding-bottom: 20px;
}

/* Icon: emoji left-aligned, sin caja */
.pq-point-icon {
  width: auto; height: auto; border-radius: 0;
  border: none; background: none;
  display: flex; align-items: center; justify-content: flex-start;
  font-size: 26px;
  margin-bottom: 10px;
  padding: 0;
}

/* ── Tablet (900-1200px): foto izquierda pequeña + 2×2 grid derecha ── */
@media (max-width: 1200px) and (min-width: 900px) {
  .pq-wrapper { padding: 0 24px 64px; }
  .pq-layout {
    grid-template-columns: 200px 1fr;
    gap: 32px;
    align-items: start;
  }
  .pq-photo-wrap {
    position: static;
    width: 200px;
    height: 260px;
    border-radius: 16px;
  }
  .pq-points-scroll {
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .pq-point-card { padding: 12px 12px 12px 0; }
  .pq-points-scroll .pq-point:nth-child(even) .pq-point-card {
    padding-left: 16px;
    padding-right: 0;
  }
}
.pq-point-title {
  font-family: 'Poppins', system-ui, sans-serif;
  font-size: 16px; font-weight: 700;
  color: #fff; line-height: 1.3; margin-bottom: 10px;
}
.pq-point-desc {
  font-size: 13.5px; color: rgba(255,255,255,0.90); line-height: 1.65;
}

/* Swipe hint: hidden on desktop */
.pq-swipe-hint { display: none; }
.pq-sub-mobile { display: none; }

/* ── Mobile ── */
@media (max-width: 899px) {
  .pq-sub-desktop { display: none; }
  .pq-sub-mobile  { display: block; }
  .pq-wrapper { padding: 0 0 64px; background: #fff; }
  .pq-outer { border-radius: 24px; }
  .pq-section { padding: 64px 0 48px; }
  .pq-layout { display: flex; flex-direction: column; gap: 24px; }

  /* Photo: visible at top, compact */
  .pq-photo-col { display: flex; width: 100%; padding: 0 24px; box-sizing: border-box; }
  .pq-photo-wrap {
    position: static; height: auto; border-radius: 16px;
    width: 100%; aspect-ratio: 16/9; overflow: hidden;
  }
  .pq-photo { width: 100%; height: 100%; object-fit: cover; aspect-ratio: unset; }

  /* Horizontal scroll cards */
  .pq-points-col { width: 100%; }
  .pq-points-scroll {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    margin: 0 -24px;
    padding: 4px 24px 12px;
    scrollbar-width: none;
  }
  .pq-points-scroll::-webkit-scrollbar { display: none; }
  .pq-point {
    min-width: 72vw;
    max-width: 260px;
    flex-shrink: 0;
    scroll-snap-align: start;
  }
  /* Mobile card: no background */
  .pq-point-card {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 18px 16px;
    height: auto;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 14px;
  }
  .pq-points-scroll .pq-point:nth-child(even) .pq-point-card {
    padding-left: 16px;
    border-left: none;
  }
  .pq-points-scroll .pq-point:nth-last-child(-n+2) .pq-point-card {
    border-bottom: none;
    padding-bottom: 18px;
  }

  /* Mobile icon: emoji left, vertically centered */
  .pq-point-icon {
    width: auto; height: auto; border: none; background: none;
    border-radius: 0; font-size: 30px; margin-bottom: 0;
    padding: 0; flex-shrink: 0; align-self: center;
  }

  .pq-point-text { flex: 1; display: flex; flex-direction: column; }
  .pq-point-card .pq-point-title { margin-bottom: 4px; }

  .pq-point-title { font-size: 15px; }
  /* Clamp description to 3 lines on mobile */
  .pq-point-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.90);
    line-height: 1.55;
  }

  /* Swipe hint: visible on mobile */
  .pq-swipe-hint {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.45);
    letter-spacing: 0.03em;
    padding: 4px 24px 0;
    margin-top: 4px;
  }
}
</style>
