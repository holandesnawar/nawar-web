---
---
<footer class="footer-nuevo" id="contacto" data-navbar="dark">

  <!-- Card "Aprende como el 1%" -->
  <div class="footer-signup-wrap">
    <div class="footer-signup-card">
      <div class="footer-signup-glow" aria-hidden="true"></div>
      <div class="footer-signup-inner">
        <h2 class="footer-signup-title">Aprende como el 1%</h2>
        <ul class="footer-signup-perks">
          <li>
            <svg width="16" height="16" fill="none" stroke="#1D0084" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Diseñado para hispanohablantes
          </li>
          <li>
            <svg width="16" height="16" fill="none" stroke="#1D0084" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Sin experiencia previa necesaria
          </li>
          <li>
            <svg width="16" height="16" fill="none" stroke="#1D0084" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Garantía 15 días, reembolso completo
          </li>
        </ul>
        <div id="footer-signup-success" class="footer-signup-success" style="display:none;">
          <svg width="16" height="16" fill="none" stroke="#1D0084" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          ¡Perfecto! Pronto recibirás noticias de nosotros.
        </div>
        <form id="footer-signup-form" class="footer-signup-form">
          <input id="footer-signup-email" type="email" class="footer-signup-input" placeholder="Introduce tu correo electrónico" autocomplete="email" required>
          <button type="submit" class="footer-signup-btn">
            Lista de espera
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </button>
        </form>
        <p class="footer-signup-privacy">
          Al hacer clic, confirmo que he leído y aceptado la <a href="#">política de privacidad</a>.
        </p>
      </div>
    </div>
  </div>

  <!-- Footer links -->
  <div class="footer-main">
    <div class="footer-grid">
      <div>
        <img src="https://d1yei2z3i6k35z.cloudfront.net/9533860/671a9c9265e23_Logo_Nawar_2.png" alt="Holandés Nawar" class="footer-logo">
        <p class="footer-tagline">Academia online de neerlandés para hispanohablantes. Aprende de verdad, con método y comunidad.</p>
        <div class="footer-socials">
          <!-- Instagram -->
          <a href="https://www.instagram.com/holandes.nawar" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social-btn">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <!-- Facebook -->
          <a href="#" aria-label="Facebook" class="footer-social-btn">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <!-- Mail -->
          <a href="mailto:hola@holandesnawar.com" aria-label="Email" class="footer-social-btn">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <p class="footer-col-label">Navegación</p>
        <ul class="footer-nav">
          <li><a href="/">Inicio</a></li>
          <li><a href="/nuestra-vision">Nuestra Visión</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-label">Contacto</p>
        <ul class="footer-contact">
          <li><a href="mailto:hola@holandesnawar.com">hola@holandesnawar.com</a></li>
          <li><a href="https://www.instagram.com/holandes.nawar" target="_blank" rel="noopener noreferrer">@holandes.nawar</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-label">Legal</p>
        <ul class="footer-nav">
          <li><a href="#">Términos y condiciones</a></li>
          <li><a href="#">Política de privacidad</a></li>
          <li><a href="#">Cookies</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">© <span id="footer-year"></span> HOLANDÉS NAWAR. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<script>
  const y = document.getElementById('footer-year');
  if (y) y.textContent = String(new Date().getFullYear());

  const form = document.getElementById('footer-signup-form');
  const success = document.getElementById('footer-signup-success');
  if (form && success) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      (form as HTMLElement).style.display = 'none';
      (success as HTMLElement).style.display = 'flex';
    });
  }
</script>
