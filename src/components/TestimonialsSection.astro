---
interface Testimonial { name: string; origin: string; text: string; stars: number; avatar: string }
interface Props { testimonials: Testimonial[] }
const { testimonials } = Astro.props

const delayClass = (i: number) => ['','d1','d2','d3'][i % 4]
---

<section data-navbar="dark" id="opiniones" class="relative bg-[#1D0084] overflow-hidden pt-24 pb-10">
  <div aria-hidden class="absolute inset-0 pointer-events-none">
    <div
      class="absolute -top-20 left-1/2 -translate-x-1/2 w-[900px] h-[600px]"
      style="background: radial-gradient(ellipse at top center, rgba(11,109,240,0.40) 0%, transparent 65%)"
    />
  </div>
  <div aria-hidden class="absolute inset-0 dots-dark pointer-events-none" />

  <div class="relative max-w-6xl mx-auto px-6">

    <div class="text-center max-w-2xl mx-auto mb-20 space-y-5">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#025dc7] text-[#e0f2ff] eyebrow">
        <svg class="w-3 h-3 shrink-0" viewBox="0 0 12 12" fill="none">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Resultados reales
      </span>
      <h2 class="title text-white">
        Hispanohablantes que ya{' '}
        <span class="text-[#4da3ff]">hablan neerlandés</span>
      </h2>
      <p class="text-[18px] text-white/50 leading-relaxed max-w-md mx-auto">
        Más de 600 estudiantes. Algunos de sus testimonios.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {testimonials.map((t, i) => (
        <div class={`sr-s ${delayClass(i)} bg-white border border-[#DDE6F5] rounded-2xl p-8 flex flex-col gap-6 h-full`}>
          <div class="flex gap-1">
            {Array.from({ length: t.stars }).map(() => (
              <svg class="w-4 h-4 fill-[#F58220]" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <blockquote class="text-[15px] text-[#1D0084]/65 leading-relaxed flex-1">
            &ldquo;{t.text}&rdquo;
          </blockquote>
          <div class="flex items-center gap-3 pt-5 border-t border-[#1D0084]/10">
            <div class="w-10 h-10 rounded-full bg-[#1D0084]/10 border border-[#1D0084]/15 flex items-center justify-center text-[#1D0084] font-bold text-[12px] shrink-0">
              {t.avatar}
            </div>
            <div>
              <p class="text-[#1D0084] font-semibold text-[14px]">{t.name}</p>
              <p class="text-[#1D0084]/45 text-[12px] mt-0.5">{t.origin}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
