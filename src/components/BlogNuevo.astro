---
import { getCollection } from 'astro:content'

const entries = await getCollection('blog')
const posts = entries
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3)
  .map((e) => ({
    title: e.data.title,
    slug: e.slug,
    publishedAt: e.data.publishedAt.toISOString(),
    excerpt: e.data.excerpt,
    category: e.data.category,
    mainImage: e.data.mainImage,
    readingMinutes: e.data.readingMinutes,
  }))

const fmt = (d: string) =>
  new Date(d).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })

const CATEGORY_META: Record<string, { label: string; className: string }> = {
  inburgering:   { label: 'Inburgering',   className: 'bn-chip--inbu' },
  cultura:       { label: 'Cultura',       className: 'bn-chip--cult' },
  vocabulario:   { label: 'Vocabulario',   className: 'bn-chip--voca' },
  pronunciacion: { label: 'Pronunciación', className: 'bn-chip--pron' },
}
---

<section class="section-light blog-section" data-navbar="light" style="position:relative;overflow:hidden;">
  <div class="dots-light" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></div>
  <div class="inner">

    <!-- Badge + título (título oculto en móvil) -->
    <div class="blog-header-wrap">
      <span class="badge-light" style="letter-spacing:0.06em;text-transform:none;font-size:12px;padding:6px 14px;">
        BLOG · HOLANDÉS NAWAR
      </span>
      <h2 class="title blog-title-desktop" style="color:#1D0084;margin-bottom:0;white-space:nowrap;">Nuestros últimos artículos</h2>
    </div>

    <!-- DESKTOP: grid 3 tarjetas blancas -->
    <div class="blog-grid-desktop">
      {posts.length === 0 ? (
        <div class="bn-card bn-card--empty">
          <div class="bn-body">
            <h3 class="bn-title">Artículos sobre neerlandés en camino</h3>
            <p class="bn-date">Próximamente</p>
            <span class="bn-read">
              Ver el blog
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
            </span>
          </div>
        </div>
      ) : (
        posts.map((post: any, i: number) => {
          const cat = post.category ? CATEGORY_META[post.category] : null
          const mins = Math.max(1, Number(post.readingMinutes) || 3)
          return (
            <a href={`/blog/${post.slug}`} class={`bn-card sr${i > 0 ? ` d${i}` : ''}`} style={`--ci:${i}`}>
              {post.mainImage?.src && (
                <div class="bn-img">
                  <img src={post.mainImage.src} alt={post.mainImage.alt || post.title} loading="lazy" width="600" height="360" />
                </div>
              )}
              <div class="bn-body">
                <div class="bn-meta">
                  {cat
                    ? <span class={`bn-chip ${cat.className}`}>{cat.label}</span>
                    : <span />}
                  <span class="bn-reading">
                    <svg class="bn-reading-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="8" cy="8" r="6.25"/>
                      <path d="M8 4.5V8l2.25 1.25"/>
                    </svg>
                    {mins} min lectura
                  </span>
                </div>
                <h3 class="bn-title">{post.title}</h3>
                {post.publishedAt && <p class="bn-date">{fmt(post.publishedAt)}</p>}
                {post.excerpt && <p class="bn-excerpt">{post.excerpt}</p>}
                <span class="bn-read">
                  Leer artículo
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
                </span>
              </div>
            </a>
          )
        })
      )}
    </div>

    <!-- MOBILE: slider con mismas tarjetas blancas -->
    <div class="blog-slider-mobile">
      {posts.map((post: any) => {
        const cat = post.category ? CATEGORY_META[post.category] : null
        const mins = Math.max(1, Number(post.readingMinutes) || 3)
        return (
          <a href={`/blog/${post.slug}`} class="bn-card bsm-card">
            {post.mainImage?.src && (
              <div class="bn-img">
                <img src={post.mainImage.src} alt={post.mainImage.alt || post.title} loading="lazy" />
              </div>
            )}
            <div class="bn-body">
              <div class="bn-meta">
                {cat
                  ? <span class={`bn-chip ${cat.className}`}>{cat.label}</span>
                  : <span />}
                <span class="bn-reading">
                  <svg class="bn-reading-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="8" cy="8" r="6.25"/>
                    <path d="M8 4.5V8l2.25 1.25"/>
                  </svg>
                  {mins} min
                </span>
              </div>
              <h3 class="bn-title">{post.title}</h3>
              {post.publishedAt && <p class="bn-date">{fmt(post.publishedAt)}</p>}
              <span class="bn-read">
                Leer artículo
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
              </span>
            </div>
          </a>
        )
      })}
    </div>

  </div>
</section>

<style>
  .blog-section { padding: 96px 0 64px; }
  .blog-header-wrap {
    text-align: center; max-width: 640px; margin: 0 auto 52px;
    display: flex; flex-direction: column; align-items: center; gap: 12px;
  }

  /* ── Tarjeta blanca profesional ── */
  .bn-card {
    position: relative;
    display: flex; flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    background: #FFFFFF;
    border: 1px solid #E5EAF2;
    box-shadow:
      0 1px 2px rgba(29,0,132,0.04),
      0 6px 20px rgba(29,0,132,0.05);
    transition: transform .22s ease-out, box-shadow .22s ease-out, border-color .22s ease-out;
  }
  .bn-card:hover {
    transform: translateY(-3px);
    border-color: #CFDDF4;
    box-shadow:
      0 2px 4px rgba(29,0,132,0.05),
      0 14px 36px rgba(29,0,132,0.10);
  }

  /* ── Image ── */
  .bn-img {
    overflow: hidden;
    flex-shrink: 0;
    aspect-ratio: 16 / 9;
    background: #F0F5FF;
  }
  .bn-img img {
    display: block;
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .35s ease-out;
  }
  .bn-card:hover .bn-img img { transform: scale(1.035); }

  /* ── Body ── */
  .bn-body {
    padding: 18px 20px 20px;
    display: flex; flex-direction: column; gap: 10px; flex: 1;
  }
  .bn-meta {
    display: flex; align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .bn-reading {
    display: inline-flex; align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 500;
    color: #7A8599;
    white-space: nowrap;
  }
  .bn-reading-icon {
    width: 13px; height: 13px;
    flex-shrink: 0;
    color: #9CA3AF;
  }

  /* ── Category chips ── */
  .bn-chip {
    display: inline-flex; align-items: center;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    white-space: nowrap;
    border: 1px solid transparent;
  }
  .bn-chip--inbu { background: #DBEAFE; color: #1D4ED8; border-color: #BFDBFE; }
  .bn-chip--cult { background: #FEF3C7; color: #B45309; border-color: #FDE68A; }
  .bn-chip--voca { background: #D1FAE5; color: #047857; border-color: #A7F3D0; }
  .bn-chip--pron { background: #FDF2F8; color: #BE185D; border-color: #FBCFE8; }

  .bn-date {
    font-size: 12.5px;
    color: #7A8599;
    font-weight: 500;
    margin: 0;
  }
  .bn-title {
    margin: 0;
    font-family: var(--font-poppins), system-ui, sans-serif;
    font-size: 19px;
    font-weight: 700;
    line-height: 1.3;
    color: #1D0084;
    letter-spacing: -0.015em;
  }
  .bn-excerpt {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
    color: #4B5563;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bn-read {
    margin-top: 2px;
    font-size: 13px;
    font-weight: 600;
    color: #1D0084;
    display: inline-flex; align-items: center; gap: 6px;
    transition: gap .2s ease-out;
  }
  .bn-read svg { width: 14px; height: 14px; transition: transform .2s ease-out; }
  .bn-card:hover .bn-read { gap: 9px; }
  .bn-card:hover .bn-read svg { transform: translateX(2px); }

  /* Empty state card */
  .bn-card--empty { min-height: 180px; justify-content: center; }

  /* ── DESKTOP GRID ── */
  .blog-grid-desktop { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
  .blog-slider-mobile { display: none; }
  .blog-title-desktop { display: block; }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .blog-section { padding: 40px 0 40px; }
    .blog-header-wrap { margin-bottom: 24px; }
    .blog-title-desktop { display: none; }
    .blog-grid-desktop  { display: none; }

    .blog-slider-mobile {
      display: flex; gap: 14px; overflow-x: auto;
      scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
      padding: 4px 32px 12px; margin: 0 -16px; scrollbar-width: none;
    }
    .blog-slider-mobile::-webkit-scrollbar { display: none; }
    .bsm-card {
      scroll-snap-align: start; flex-shrink: 0;
      width: 78vw; min-width: 260px; max-width: 320px;
    }
    .bsm-card .bn-title { font-size: 17px; }
    .bsm-card .bn-body { padding: 16px 18px 18px; }
  }
</style>
