<section id="inicio" class="section-dark" style="min-height:95vh;display:flex;align-items:center;padding-top:72px;position:relative;overflow:hidden;" data-navbar="dark">
  <div class="hero-glow1" aria-hidden="true"></div>
  <div class="hero-glow2" aria-hidden="true"></div>
  <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></div>
  <div class="hero-inner">
    <div>
      <span class="badge-dark">
        <svg class="check-icon" fill="none" viewBox="0 0 12 12">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        Neerlandés para hispanohablantes &middot; 100% Online
      </span>
      <h1 class="hero-title">
        La última formación de <span class="accent">neerlandés</span> que comprarás en <span class="orange">toda tu vida</span>
      </h1>
      <p class="hero-sub">
        La migración a Países Bajos es una realidad. Súmate a los miles de hispanohablantes que ya dominan el neerlandés y abren nuevas oportunidades.
      </p>
      <div class="hero-ctas">
        <a href="#apuntate" class="btn-primary" style="font-size:16px;padding:16px 32px;">
          QUIERO APRENDER
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="#somos" class="btn-outline-white" style="font-size:15px;padding:16px 28px;">Ver el método</a>
      </div>
      <div class="hero-social">
        <div class="hero-avatars">
          <div class="hero-avatar">AG</div>
          <div class="hero-avatar">CM</div>
          <div class="hero-avatar">LP</div>
          <div class="hero-avatar">RV</div>
          <div class="hero-avatar">SM</div>
        </div>
        <div>
          <div class="hero-stars">
            <svg class="h-star" viewBox="0 0 20 20" fill="#F58220"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
