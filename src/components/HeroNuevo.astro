            <div class="lc-vitem"><p class="lc-vitem-nl">alsjeblieft</p><p class="lc-vitem-es">por favor</p></div>
          </div>
        </div>
        <div class="float-badge fb-top">
          <span style="font-size:20px;">🔥</span>
          <div><p>Racha de 7 días</p><p>¡Sigue así!</p></div>
        </div>
        <div class="float-badge fb-bot">
          <span style="font-size:18px;">🇪🇸🇲🇽🇦🇷</span>
          <div><p>24 estudiantes</p><p>en esta clase</p></div>
        </div>
      </div>
