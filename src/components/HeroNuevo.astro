---
interface Props { data?: any }
const { data } = Astro.props
const badge      = data?.badge      ?? 'Neerlandés para hispanohablantes'
const titleLine1 = data?.titleLine1 ?? 'Aprende neerlandés'
const titleLine2 = data?.titleLine2 ?? 'de verdad'
const subtitle   = data?.subtitle   ?? 'El método que debería haber existido desde siempre para cualquier hispanohablante que quiere aprender neerlandés.'
const bullets    = data?.bullets?.length ? data.bullets : [
  'Explicado desde el español, sin pasar por el inglés',
  'Sin experiencia previa — desde cero hasta conversar',
  'Comunidad activa de +600 hispanohablantes',
]
const ctaText    = data?.ctaText    ?? 'Únete a la lista de espera'
---
<section id="inicio" class="hero-section" data-navbar="dark">
  <div class="hero-glow1" aria-hidden="true"></div>
  <div class="hero-glow2" aria-hidden="true"></div>
  <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></div>

  <div class="hero-wrap">

    <!-- LEFT: visual card -->
    <div class="hero-col-card">
      <div class="lesson-card h-anim" style="--hd:0.2s">
        <div class="lesson-card-inner">
          <div class="lc-header">
            <div class="lc-icon">🎓</div>
            <div>
              <p class="lc-title">Vista previa de la experiencia</p>
              <p class="lc-sub">Módulo A1 · Primera edición</p>
            </div>
            <span class="lc-live"><span class="lc-live-dot"></span><span class="lc-live-text">En vivo</span></span>
          </div>
          <p class="lc-label">Lección 6</p>
          <p class="lc-lesson-title">Los verbos en presente 🇳🇱</p>
          <div class="lc-prog-row"><span>Formato del módulo</span><span>8 lecciones</span></div>
          <div class="lc-prog-bar"><div class="lc-prog-fill"></div></div>
          <div class="lc-vocab">
            <div class="lc-vitem"><p class="lc-vitem-nl">goedemorgen</p><p class="lc-vitem-es">buenos días</p></div>
            <div class="lc-vitem"><p class="lc-vitem-nl">tot ziens</p><p class="lc-vitem-es">hasta luego</p></div>
            <div class="lc-vitem"><p class="lc-vitem-nl">dank je wel</p><p class="lc-vitem-es">muchas gracias</p></div>
            <div class="lc-vitem"><p class="lc-vitem-nl">alsjeblieft</p><p class="lc-vitem-es">por favor</p></div>
          </div>
        </div>
        <div class="float-badge fb-top">
          <span style="font-size:20px;">🔥</span>
          <div><p>Próxima edición</p><p>Plazas limitadas</p></div>
        </div>
        <div class="float-badge fb-bot">
          <span style="font-size:18px;">🇪🇸🇲🇽🇦🇷</span>
          <div><p>Sesiones en vivo</p><p>incluidas desde el día 1</p></div>
        </div>
      </div>
    </div>

    <!-- RIGHT: text content -->
    <div class="hero-col-text">
      <span class="badge-dark h-anim" style="--hd:0.08s">
        <svg class="check-icon" fill="none" viewBox="0 0 12 12">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        {badge}
      </span>

      <h1 class="hero-title h-anim" style="--hd:0.18s">
        <span class="hero-title-gradient">{titleLine1}</span><br>
        <span style="color: #4da3ff; -webkit-text-fill-color: #4da3ff;">{titleLine2}</span>
      </h1>

      <p class="hero-sub h-anim" style="--hd:0.28s">
        {subtitle}
      </p>

      <ul class="hero-bullets h-anim" style="--hd:0.38s">
        {bullets.map((item: string) => (
          <li>
            <span class="hero-check">
              <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>

      <div class="hero-form-row h-anim" id="lista-espera" style="--hd:0.48s">
        <form id="hero-signup-form" class="hero-form">
          <input
            id="hero-email"
            type="email"
            placeholder="Introduce tu correo electrónico"
            class="hero-email-input"
            autocomplete="email"
            required
          />
          <button type="submit" class="hero-form-btn">
            {ctaText}
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </button>
        </form>
        <div id="hero-signup-success" class="hero-success" style="display:none;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
          ¡Perfecto! Te avisamos en cuanto abramos plazas.
        </div>
      </div>

      <p class="hero-privacy h-anim" style="--hd:0.55s">
        Al hacer clic, confirmo que he leído y aceptado la <a href="/politica-de-privacidad">política de privacidad</a>.
      </p>
    </div>

  </div>

  <!-- Flags strip -->
  <div class="hero-flags-strip">
    <div style="text-align:center;margin-bottom:20px;">
      <span class="badge-dark" style="white-space:nowrap;">
        <svg class="check-icon" fill="none" viewBox="0 0 12 12">
          <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Estudiantes de todo el mundo
      </span>
    </div>
    <div style="position:relative;overflow:hidden;">
      <div style="pointer-events:none;position:absolute;top:0;bottom:0;left:0;width:80px;background:linear-gradient(to right,#1D0084,transparent);z-index:10;"></div>
      <div style="pointer-events:none;position:absolute;top:0;bottom:0;right:0;width:80px;background:linear-gradient(to left,#1D0084,transparent);z-index:10;"></div>
      <div class="ticker-flags" style="display:flex;gap:12px;white-space:nowrap;will-change:transform;">
        <span class="flag-item">🇲🇽 México</span>
        <span class="flag-item">🇦🇷 Argentina</span>
        <span class="flag-item">🇨🇴 Colombia</span>
        <span class="flag-item">🇨🇱 Chile</span>
        <span class="flag-item">🇵🇪 Perú</span>
        <span class="flag-item">🇻🇪 Venezuela</span>
        <span class="flag-item">🇪🇨 Ecuador</span>
        <span class="flag-item">🇧🇴 Bolivia</span>
        <span class="flag-item">🇵🇾 Paraguay</span>
        <span class="flag-item">🇺🇾 Uruguay</span>
        <span class="flag-item">🇵🇦 Panamá</span>
        <span class="flag-item">🇨🇷 Costa Rica</span>
        <span class="flag-item">🇬🇹 Guatemala</span>
        <span class="flag-item">🇸🇻 El Salvador</span>
        <span class="flag-item">🇩🇴 Rep. Dominicana</span>
        <span class="flag-item">🇨🇺 Cuba</span>
        <span class="flag-item">🇵🇷 Puerto Rico</span>
        <span class="flag-item">🇪🇸 España</span>
        <span class="flag-item">🇲🇽 México</span>
        <span class="flag-item">🇦🇷 Argentina</span>
        <span class="flag-item">🇨🇴 Colombia</span>
        <span class="flag-item">🇨🇱 Chile</span>
        <span class="flag-item">🇵🇪 Perú</span>
        <span class="flag-item">🇻🇪 Venezuela</span>
        <span class="flag-item">🇪🇨 Ecuador</span>
        <span class="flag-item">🇧🇴 Bolivia</span>
        <span class="flag-item">🇵🇾 Paraguay</span>
        <span class="flag-item">🇺🇾 Uruguay</span>
        <span class="flag-item">🇵🇦 Panamá</span>
        <span class="flag-item">🇨🇷 Costa Rica</span>
        <span class="flag-item">🇬🇹 Guatemala</span>
        <span class="flag-item">🇸🇻 El Salvador</span>
        <span class="flag-item">🇩🇴 Rep. Dominicana</span>
        <span class="flag-item">🇨🇺 Cuba</span>
        <span class="flag-item">🇵🇷 Puerto Rico</span>
        <span class="flag-item">🇪🇸 España</span>
      </div>
    </div>
  </div>
</section>

<style>
/* ── Load animation ── */
@keyframes h-in {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.h-anim {
  opacity: 0;
  animation: h-in 0.75s cubic-bezier(0.22,1,0.36,1) forwards;
  animation-delay: var(--hd, 0s);
}

/* ── Section ── */
.hero-section {
  background: #1D0084;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ── Gradient title effect — per-letter (repeats each em) ── */
.hero-title-gradient {
  background: linear-gradient(180deg, rgba(255,255,255,1) 0%, rgba(255,255,255,0.45) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Two-column wrapper ── */
.hero-wrap {
  flex: 1;
  max-width: 1152px;
  margin: 0 auto;
  padding: 120px 32px 64px;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: 72px;
  align-items: center;
  position: relative;
  z-index: 1;
}

/* ── Left: card column ── */
.hero-col-card {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── Right: text column ── */
.hero-col-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* ── Title / sub ── */
.hero-col-text .hero-title {
  margin-top: 0;
  margin-bottom: 16px;
}
.hero-col-text .hero-sub {
  font-size: clamp(15px, 1.4vw, 17px);
  max-width: 480px;
  margin-bottom: 24px;
  color: #ffffff;
}

/* ── Bullets ── */
.hero-bullets {
  list-style: none;
  padding: 0;
  margin: 0 0 28px 0;
  display: flex;
  flex-direction: column;
  gap: 13px;
}
.hero-bullets li {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 16px;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.45;
}
.hero-check {
  flex-shrink: 0;
  width: 22px; height: 22px;
  border-radius: 50%;
  background: transparent;
  border: 2px solid #4da3ff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4da3ff;
}

/* ── Form row ── */
.hero-form-row { width: 100%; max-width: 540px; margin-bottom: 10px; }
.hero-form {
  display: flex;
  gap: 8px;
  width: 100%;
}
.hero-email-input {
  flex: 1;
  min-width: 0;
  padding: 16px 18px;
  border-radius: 10px;
  background: #fff;
  border: none;
  color: #1D0084;
  font-size: 14px;
  font-family: inherit;
  outline: none;
}
.hero-email-input::placeholder { color: #9aa5bc; }
.hero-form-btn {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 16px 24px;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  background: #4da3ff;
  color: #1D0084;
  font-size: 14px;
  font-weight: 700;
  font-family: inherit;
  white-space: nowrap;
}
.hero-success {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  padding: 12px 0;
}

/* ── Privacy ── */
.hero-privacy {
  font-size: 12px;
  color: rgba(255,253,253,0.8);
}
.hero-privacy a {
  color: rgba(255,255,255,0.55);
  text-decoration: underline;
}

/* ── Flags ── */
.hero-flags-strip {
  position: relative;
  z-index: 1;
  padding-bottom: 48px;
}
.flag-item {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 7px 15px; border-radius: 9999px;
  font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.82);
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.11);
  flex-shrink: 0;
}
@keyframes ticker-flags-kf {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.ticker-flags { animation: ticker-flags-kf 16s linear infinite; }
@media (max-width: 900px) {
  .ticker-flags { animation-duration: 4.5s; }
}

/* ── Mobile ── */
@media (max-width: 900px) {
  .hero-wrap {
    grid-template-columns: 1fr;
    padding: 100px 24px 48px;
    gap: 48px;
  }
  .hero-col-card { display: none; }
  .hero-form {
    flex-direction: column;
  }
  .hero-form-btn {
    width: 100%;
    justify-content: center;
  }
  .badge-dark { white-space: nowrap; font-size: 10px; }
  .hero-bullets li { font-size: 15px; }
}
@media (max-width: 400px) {
  .badge-dark { font-size: 9px; padding: 5px 12px; }
}
</style>

<script>
  const form    = document.getElementById('hero-signup-form') as HTMLFormElement | null
  const success = document.getElementById('hero-signup-success') as HTMLElement | null
  const btn     = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const email = (document.getElementById('hero-email') as HTMLInputElement)?.value?.trim()
    if (!email) return

    if (btn) { btn.textContent = '...'; btn.disabled = true }

    try {
      const res = await fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      })
      const data = await res.json()

      if (data.success) {
        ;(form as HTMLElement).style.display = 'none'
        if (success) success.style.display = 'flex'
      } else {
        if (btn) { btn.textContent = 'Inténtalo de nuevo'; btn.disabled = false }
        console.error('Error lista espera:', data.error)
      }
    } catch {
      if (btn) { btn.textContent = 'Error — inténtalo de nuevo'; btn.disabled = false }
    }
  })
</script>
