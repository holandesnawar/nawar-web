---
interface Props { data?: any }
const { data } = Astro.props
const badge = data?.badge ?? 'Prepárate para el cambio'
const title = data?.title ?? 'El idioma ya no es una barrera: es una ventaja competitiva.'
const subtitle = data?.subtitle ?? 'En un mundo cada vez más globalizado, hablar neerlandés te abre las puertas a mejores oportunidades laborales, migratorias y académicas en Países Bajos y Bélgica.'
const note = data?.note ?? 'Domina el neerlandés y transforma tu futuro profesional →'
const ctaPrimary = data?.ctaPrimary ?? 'Quiero empezar'
const ctaSecondary = data?.ctaSecondary ?? 'Preguntas frecuentes'
---
<section class="section-dark py-section" data-navbar="dark" style="position:relative;overflow:hidden;">
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:1000px;height:700px;background:radial-gradient(ellipse at center,rgba(11,109,240,0.35) 0%,transparent 65%);pointer-events:none;" aria-hidden="true"></div>
  <div class="dots-dark" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;"></div>
  <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,rgba(255,255,255,0.12),transparent);" aria-hidden="true"></div>
  <div class="inner">
    <div class="value-inner">
      <div class="value-left sr">
        <span class="badge-dark" style="margin-bottom:24px;">
          <svg class="check-icon" fill="none" viewBox="0 0 12 12">
            <path d="M2 6.5l2.5 2.5 5.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {badge}
        </span>
        <h2 class="value-title text-gradient-white" set:html={title.replace(/\n/g, '<br>')} />
        <p class="value-sub">{subtitle}</p>
        <p class="value-note">{note}</p>
        <div style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap;">
          <a href="#lista-espera" class="valor-cta-btn">
            {ctaPrimary}
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="#faq" class="btn-outline-white" style="font-size:15px;padding:14px 24px;">{ctaSecondary}</a>
        </div>
      </div>
      <div class="value-right sr d1">
        <div class="value-image-wrap">
          <img
            src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=600&h=500&fit=crop&q=80"
            alt="Estudiantes aprendiendo"
            class="value-image"
          />
        </div>
      </div>
    </div>
  </div>
</section>
