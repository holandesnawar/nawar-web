---
interface Props { data?: any }
const { data } = Astro.props
const badge = data?.badge ?? '¿Tienes dudas?'
const title = data?.title ?? 'Preguntas Frecuentes'
const defaultItems = [
  { question: '¿Qué es NAWAR?', answer: 'NAWAR es nuestra academia de neerlandés para hispanohablantes. Elegimos este nombre porque en árabe "Nawar" significa "flor": representa crecimiento, constancia y progreso real. Explicaciones pensadas para hispanohablantes, un método paso a paso y práctica constante desde el inicio.' },
  { question: '¿Por qué aprender neerlandés si ya hablo inglés?', answer: 'Hablar neerlandés es clave para acceder a empleos de calidad, estudios universitarios y beneficios migratorios. El inglés ayuda a "defenderse", pero quien realmente destaca es quien domina el neerlandés.' },
  { question: '¿Necesito conocimientos previos?', answer: 'No. Nuestros cursos están diseñados para hispanohablantes desde nivel 0. Usamos estructuras claras y comparaciones con el español, incluso si nunca has estudiado otro idioma.' },
  { question: '¿Qué soporte ofrecen si tengo dudas?', answer: 'Tendrás acceso a asistencia directa por email y WhatsApp, además de la comunidad privada de estudiantes donde podrás resolver dudas y practicar con otros hispanohablantes.' },
  { question: '¿Puedo estudiar a mi propio ritmo?', answer: 'Sí. Todo el contenido está disponible 24/7 y no hay horarios fijos. Tú decides cuántas horas dedicas por semana. Las clases en vivo son opcionales y quedan grabadas.' },
  { question: '¿Qué diferencia a Nawar de otras formaciones?', answer: 'Enseñamos neerlandés desde el español: gramática funcional, comprensión cultural y práctica contextual. No es una app ni una academia genérica — es el método que debería haber existido desde el principio.' },
]
const items = data?.items?.length ? data.items : defaultItems
---
<section id="faq" class="section-light faq-section" data-navbar="light" style="position:relative;overflow:hidden;">
  <!-- Schema.org FAQPage — habilita rich results de preguntas en Google -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': items.map((item: any) => ({
      '@type': 'Question',
      'name': item.question,
      'acceptedAnswer': { '@type': 'Answer', 'text': item.answer },
    })),
  })} />
  <div class="dots-light" aria-hidden="true" style="position:absolute;inset:0;pointer-events:none;opacity:0.5;"></div>
  <div class="inner">
    <div class="faq-header-wrap">
      <span class="badge-light">{badge}</span>
      <h2 class="title" style="color:#1D0084;margin-bottom:0;">{title}</h2>
    </div>

    <div class="faq-modern" id="faq-list">
      {items.map((item: any) => (
        <div class="faq-modern-item sr">
          <button class="faq-modern-btn" aria-expanded="false">
            <span class="faq-modern-q">{item.question}</span>
            <span class="faq-modern-icon">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </span>
          </button>
          <div class="faq-modern-body">
            <div class="faq-modern-content">
              <p>{item.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.faq-section {
  padding: 52px 0 96px;
}
.faq-header-wrap {
  text-align: center;
  max-width: 720px;
  margin: 0 auto 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
@media (max-width: 768px) {
  .faq-section { padding: 36px 0 48px; }
  .faq-header-wrap { margin-bottom: 28px; }
  .faq-header-wrap .title { font-size: clamp(24px, 6.5vw, 34px); }
}

.faq-modern {
  max-width: 760px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.faq-modern-item {
  background: #fff;
  border: 1px solid #E8EBF4;
  border-radius: 16px;
  overflow: hidden;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.faq-modern-item:has(.faq-modern-btn[aria-expanded="true"]) {
  border-color: rgba(2,93,199,0.25);
  box-shadow: none;
}
.faq-modern-btn {
  display: flex; justify-content: space-between; align-items: center;
  width: 100%; padding: 22px 24px; background: none; border: none;
  cursor: pointer; text-align: left; gap: 16px;
}
.faq-modern-q {
  font-size: 16px; font-weight: 600; color: #1D0084; line-height: 1.4;
  font-family: var(--font-poppins, 'Poppins'), system-ui, sans-serif;
}
.faq-modern-icon {
  flex-shrink: 0; width: 32px; height: 32px;
  border-radius: 10px; background: #F0F5FF;
  display: flex; align-items: center; justify-content: center;
  color: #1D0084;
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1), background 0.2s;
}
.faq-modern-btn[aria-expanded="true"] .faq-modern-icon {
  transform: rotate(180deg);
  background: #1D0084;
  color: #fff;
}
.faq-modern-body {
  max-height: 0; overflow: hidden;
  transition: max-height 0.38s cubic-bezier(0.4,0,0.2,1);
}
.faq-modern-content {
  padding: 0 24px 22px;
  border-top: 1px solid #E8EBF4;
}
.faq-modern-content p {
  padding-top: 18px;
  font-size: 15px; font-weight: 500; color: #1D0084; line-height: 1.75;
}
</style>

<script>
  const faqList = document.getElementById('faq-list');
  if (faqList) {
    faqList.addEventListener('click', function(e) {
      const btn = (e.target as Element).closest('.faq-modern-btn');
      if (!btn) return;
      const item = btn.closest('.faq-modern-item');
      const body = item?.querySelector('.faq-modern-body') as HTMLElement | null;
      const expanded = btn.getAttribute('aria-expanded') === 'true';

      // Close all
      faqList.querySelectorAll('.faq-modern-item').forEach((i: Element) => {
        i.querySelector('.faq-modern-btn')?.setAttribute('aria-expanded', 'false');
        const b = i.querySelector('.faq-modern-body') as HTMLElement | null;
        if (b) b.style.maxHeight = '';
      });

      if (!expanded && body) {
        btn.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
      }
    });
  }
</script>
