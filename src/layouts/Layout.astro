---
import VisualEditing from '../components/VisualEditing'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const { title = 'Nawar Academia', description = 'Aprende neerlandés con Nawar' } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <!-- Navbar -->
    <header class="border-b border-gray-100">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-semibold text-lg tracking-tight">Nawar</a>
        <ul class="flex gap-6 text-sm">
          <li><a href="/blog" class="hover:text-gray-600 transition-colors">Blog</a></li>
          <li><a href="/lista-de-espera" class="hover:text-gray-600 transition-colors">Lista de espera</a></li>
          <li><a href="/contacto" class="hover:text-gray-600 transition-colors">Contacto</a></li>
        </ul>
      </nav>
    </header>

    <!-- Contenido principal -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-100 mt-24">
      <div class="max-w-4xl mx-auto px-6 py-8 text-sm text-gray-500 flex justify-between">
        <span>© {new Date().getFullYear()} Nawar Academia</span>
        <a href="/contacto" class="hover:text-gray-900 transition-colors">Contacto</a>
      </div>
    </footer>

    <!-- Visual Editing — solo activo desde el Presentation Tool del Studio -->
    <VisualEditing client:only="react" />
  </body>
</html>
