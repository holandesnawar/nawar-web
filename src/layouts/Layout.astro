---
import '../styles/global.css'
import { VisualEditing } from '@sanity/astro/visual-editing'

interface Props {
  title?: string
  description?: string
  keywords?: string
}

const {
  title = 'Nawar — Aprende neerlandés online',
  description = 'Academia de neerlandés para hispanohablantes. Clases en vivo, método desde el español y comunidad activa.',
  keywords = 'neerlandés, holandés, curso online, hispanohablantes, clases en vivo, Países Bajos',
} = Astro.props
---

<!doctype html>
<html lang="es" style="background:#1D0084">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="https://docs.holandesnawar.com/iconos/logo.png?v=2" />
    <link rel="apple-touch-icon" href="https://docs.holandesnawar.com/iconos/logo.png?v=2" />

    <!-- Fonts: Inter + Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --font-inter: 'Inter', system-ui, sans-serif;
        --font-poppins: 'Poppins', system-ui, sans-serif;
      }
    </style>
  </head>
  <body class="min-h-screen antialiased" style="background:#1D0084">
    <slot />
    <VisualEditing enabled={true} />

    <!-- Scroll reveal: sequential stagger for .sr/.sr-s, bidirectional for .sr-bi -->
    <script>
      // Sequential stagger state
      let batchCount = 0
      let batchTimer: ReturnType<typeof setTimeout> | null = null
      const STEP = 0.08        // seconds between each element in a batch
      const MAX_DELAY = 0.32   // cap so last element never waits more than this
      const RESET_AFTER = 600  // ms of silence before resetting counter

      function resetBatch() {
        batchCount = 0
        batchTimer = null
      }

      // One-way observer — triggers as soon as element enters viewport
      const obsOnce = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return
            const el = e.target as HTMLElement
            if (batchTimer) clearTimeout(batchTimer)
            batchTimer = setTimeout(resetBatch, RESET_AFTER)
            const extra = Math.min(batchCount * STEP, MAX_DELAY)
            el.style.animationDelay = extra > 0 ? `${extra.toFixed(2)}s` : ''
            el.classList.add('vis')
            batchCount++
            obsOnce.unobserve(el)
          })
        },
        { threshold: 0.06, rootMargin: '0px 0px 0px 0px' }
      )

      // Bidirectional observer (keeps observing to reverse on exit)
      let biCount = 0
      let biTimer: ReturnType<typeof setTimeout> | null = null

      const obsBi = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            const el = e.target as HTMLElement
            if (e.isIntersecting) {
              if (biTimer) clearTimeout(biTimer)
              biTimer = setTimeout(() => { biCount = 0; biTimer = null }, RESET_AFTER)
              const delay = Math.min(biCount * STEP, MAX_DELAY)
              el.style.transitionDelay = delay > 0 ? `${delay.toFixed(2)}s` : '0s'
              el.classList.add('vis')
              biCount++
            } else {
              el.style.transitionDelay = '0s'
              el.classList.remove('vis')
            }
          })
        },
        { threshold: 0.06, rootMargin: '0px 0px 0px 0px' }
      )

      document.querySelectorAll('.sr, .sr-s').forEach((el) => obsOnce.observe(el))
      document.querySelectorAll('.sr-bi').forEach((el) => obsBi.observe(el))
    </script>
  </body>
</html>
