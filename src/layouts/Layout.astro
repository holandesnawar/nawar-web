---
import '../styles/global.css'
import { VisualEditing } from '@sanity/astro/visual-editing'

interface Props {
  title?: string
  description?: string
  keywords?: string
}

const {
  title = 'Nawar — Aprende neerlandés online',
  description = 'Academia de neerlandés para hispanohablantes. Clases en vivo, método desde el español y comunidad activa.',
  keywords = 'neerlandés, holandés, curso online, hispanohablantes, clases en vivo, Países Bajos',
} = Astro.props
---

<!doctype html>
<html lang="es" style="background:#1D0084">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Inter + Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --font-inter: 'Inter', system-ui, sans-serif;
        --font-poppins: 'Poppins', system-ui, sans-serif;
      }
    </style>
  </head>
  <body class="min-h-screen antialiased" style="background:#1D0084">
    <slot />
    <VisualEditing enabled={true} />

    <!-- Scroll reveal: watches .sr and .sr-s elements and adds .vis on intersection -->
    <script>
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('vis')
              obs.unobserve(e.target)
            }
          })
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      )
      document.querySelectorAll('.sr, .sr-s').forEach((el) => obs.observe(el))
    </script>
  </body>
</html>
